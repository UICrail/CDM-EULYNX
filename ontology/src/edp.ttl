<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#SafetyDistance> a owl:Class ;
    rdfs:label "SafetyDistance" ;
    rdfs:comment "The safety distance must be specialised into an (ETCS) overlap or a distance to dangerpoint." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#hasDesignSlope_SafetyDistance> ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#isLocatedAt_SafetyDistance> ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#hasMinimalLength> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointUnionOf ( <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#DistanceToDangerpoint> <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#Overlap> ) ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#DirectionAuthorityDependentOverlap>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#SwingingOverlap> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_describer#TrainDescriberStepping> a owl:Class ;
    rdfs:label "TrainDescriberStepping" ;
    rdfs:subClassOf [ a owl:Restriction ;

                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>identityOnTcsBus
Identity string of the present sub-station on the TCS-bus.
de-DE: KUs-Kennung auf ZBS</rdfs:comment>
        <rdfs:comment>ipAddressOnTcsBus
IP-address of the present substation on the TCS-bus to which this sub-station is a gateway.
de-DE: IP-Adresse COM-Server</rdfs:comment>
        <rdfs:label>TrDrSubstationWithGateway</rdfs:label>
    </owl:Class>
    



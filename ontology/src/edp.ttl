    rdfs:label "TpwsFrequencyTypes" ;
    rdfs:comment """TPWS frequencies for arming and trigger loops. The loops are stated to be Normal or Opposite direction.
<ol>
	<li>f1 - 64.25 kHz</li>
	<li>f2 - 65.25 kHz</li>
	<li>f3 - 66.25 kHz</li>
	<li>f4 - 64.75 kHz</li>

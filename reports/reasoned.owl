        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#TrafficFlow"/>
        <rdfs:comment>A location used in scheduling.
Timing points indicate where trains are supposed to pass at a scheduled time.</rdfs:comment>
        <rdfs:label>TimingPoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#TrafficFlow -->


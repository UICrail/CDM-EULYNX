        <skos:prefLabel>trainInitiatedTrigger</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#scheme_OverlapReleaseConditionTypes_EAID_69ACD5BF_946E_43e2_B85E_CBA4580E50F7 -->

    <owl:NamedIndividual rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#scheme_OverlapReleaseConditionTypes_EAID_69ACD5BF_946E_43e2_B85E_CBA4580E50F7">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment>startTimerAfterVacating
Overlap release timer starts when train clears the TVP section. 
Typically used in reversing scenarios.</rdfs:comment>
        <rdfs:comment>startTimerUponOccupation
Overlap release timer starts when train occupies the TVP section, normally the berthing track.</rdfs:comment>
        <rdfs:comment>trainInitiatedTrigger
Trackside releases the overlap only after train is proven in standstill by ETCS system or by a manual command.</rdfs:comment>
        <rdfs:label>OverlapReleaseConditionTypes</rdfs:label>
    </owl:NamedIndividual>
    



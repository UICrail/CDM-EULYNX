<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStopMovement> a owl:Class ;
    rdfs:label "NonStopMovement" ;
    rdfs:comment "Indicates whether the train may proceed beyond the signal with or without stopping." ;

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#InsulatedRailJoint> a owl:Class ;
    rdfs:label "InsulatedRailJoint" ;
    rdfs:comment """Electric (galvanic) separation joint. The rail is cut.
These joints can be situated at the extremity of a track circuit. 
They are also used <i>inside </i>TDS sections, where they do not limit a track circuit. For instance point sections where track return current needs a change of the earth rail.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#singleRail_InsulatedRailJoint> ;
            owl:someValuesFrom xsd:boolean ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponent> .


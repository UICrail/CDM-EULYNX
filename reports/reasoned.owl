        <rdfs:label>DiamondComponentSide</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#scheme_MechanismTypes_EAID_81F76E0C_713C_4d1a_9BDE_3F549BA808D6 -->

    <owl:NamedIndividual rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#scheme_MechanismTypes_EAID_81F76E0C_713C_4d1a_9BDE_3F549BA808D6">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment>handOperated
Local manual operation by hand-pulled levers. Forces can be transmitted by rods but over a short distance. When forces are transmitted over longer wires and rods, powering is considered mechanical.</rdfs:comment>
        <rdfs:comment>mechanical
Power is transmitted via wires or bars over larger distances.</rdfs:comment>
        <rdfs:label>MechanismTypes</rdfs:label>
    </owl:NamedIndividual>
    



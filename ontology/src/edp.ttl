<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#RegisteredIntrinsicCoordinate> a owl:Class ;
    rdfs:label "RegisteredIntrinsicCoordinate" ;
    rdfs:comment """A point stored in a GIS with an address. The point is typically situated at the ends of alignment segments. Used for track and line alignment.   
de-DE: GEO_Knoten""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#atPort> ;
            owl:someValuesFrom topo:Port ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "4"^^xsd:nonNegativeInteger ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass topo:Port ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#atPort> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#Line>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#LinearElement>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#PositionedRelationSet>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#TerminalElement>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#VerticalAligmentSegment> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#PlanningCorrection> a owl:Class ;
    rdfs:label "PlanningCorrection" ;
    rdfs:comment "Class that allows highlighting the differences between a approved data release and a revised data release. This helps V&amp;V staff evaluate the desired corrections.",
        """basedOnProjectStage
Human-readable designation of a project stage that was the basis for this correction.
This may be an external file not delivered in the present file.""",
        """correctionType
The type of correction, indicating the severity of the change. This acts as a hint to the kind of attention that V&amp;V should pay.
de-DE: &#196;nderungsmitteilung""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#basedOnProjectStage> ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#hasCorrectedProjectStage> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData> ],
        [ a owl:Restriction ;

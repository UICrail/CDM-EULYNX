<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Common#Designation> a owl:Class ;
    rdfs:label "Designation" ;
    rdfs:comment """Dutch track assets are labeled with a series of strings:
areaname + areatype + assetname + assettype

E.g.  areaname="Ut", areatype="Wisselgebied", assetname="41A", assettype="Wissel\"""" ;

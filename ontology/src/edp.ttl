            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#hasFourWireInterface> ;
            owl:someValuesFrom xsd:boolean ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAssetConfiguration> ;
    owl:disjointUnionOf ( <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointCrossingElementConfiguration> <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#DerailerElementConfiguration> ) .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#PhysicalSignal> a owl:Class ;
    rdfs:label "PhysicalSignal" ;
    rdfs:comment "A signal with a physical line-side appearance." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#OppositeTrackSignal> a owl:Class ;
    rdfs:label "OppositeTrackSignal" ;
    rdfs:comment """Applies to a signal whose direction is opposite to the normal direction of traffic, that is a signal applying to trains travelling on the opposite track.

Applies to double track lines only.
Not to be confused with the topological direction of the linear element, which is not related to the direction of traffic.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#appliesToSignal_OppositeTrackSignal> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#BackToBackLocking>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RestrictedArea> a owl:Class ;
    rdfs:label "RestrictedArea" ;
    rdfs:comment """Track area not usable for normal operation <i>over longer periods</i>. Construction activities are planned or taking place. The process and the time frames when activities take place are separated from the area.
NR: Track area under possession, SDEF blue area during a given time frame""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType> a owl:Class ;
    rdfs:label "TrackType" ;
    rdfs:comment """Operational classification that applies to track.
In case no suitable specialisation of this class is available, instantiate a TrackType with an appropriate Annotation or Description inherited from the Configured Base Object and that describes the needed type.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RestrictedArea>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialGauge> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponent> a owl:Class ;
    rdfs:label "TdsComponent" ;
    rdfs:comment """Line-side component of a train detection installation, typically a rail joint or axle counter head. 
It is located at a spot location at one TVP boundary, i.e. the spot up to where the train detection can safely detect train vacancy. The TVP section extremities must coincide exactly with these spot locations.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehiclePassageDetector> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#scheme_ResetStrategyTypes_EAID_14E848C5_E666_4d1d_9EAA_A96E3A3377B0> a skos:ConceptScheme ;
    rdfs:label "ResetStrategyTypes" ;
    rdfs:comment "The types of reset strategies that inform the restrictions for forcing a TDS section to clear (RFC)." .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointRelation> a owl:Class ;
    rdfs:label "CableJointRelation" ;
    rdfs:comment "Individual relation between two cables. Describes a logical tie between cable A and B." ;
    rdfs:subClassOf [ a owl:Restriction ;

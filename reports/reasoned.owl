        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:inScheme rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Working_safety#scheme_LockoutDeviceTypes_EAID_694D2FDE_D466_4a06_AA5E_055150FBFF1E"/>

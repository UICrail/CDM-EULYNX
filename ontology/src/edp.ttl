<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#KeyReleaseInstrument> a owl:Class ;
    rdfs:label "KeyReleaseInstrument" ;
    rdfs:comment """A device that releases control over an asset by releasing a key.
When the key is released, the interlocking gets no status information about the track asset, and the staff can use the key to mechanically unlock and work the asset locally.
The instrument "hides" the locked element from the interlocking.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#ReleaseInstrument> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#PointLock> a owl:Class ;
    rdfs:label "PointLock" ;
    rdfs:comment """Lock attached to a clamp that prevents point blades from moving. The movable element is found through the asset-in-state relation.
Not to be confused with the <a href="$element://{5843BDE9-40E5-45da-9B71-D296F1DD076B}"><font color="#0000ff"><u>facing point lock</u></font></a> which is  a (remotely operated) movable component.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#isMountedOnSide_PointLock> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#Lock> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#scheme_AccessabilityTypes_EAID_A08521E4_C820_4d31_B3A5_AAAC5FAA704D> a skos:ConceptScheme ;
    rdfs:label "AccessabilityTypes" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TechnologyType> a owl:Class ;
    rdfs:label "TechnologyType" ;
    rdfs:comment """The designation of the applied technology.
 E.g. the supplier designation: "Siemens LC", "EBUET 80".
<ul>
	<li>de-DE: e.g. Anrufschranke, BUES2000</li>
	<li>it-IT: PL privati</li>
	<li>nl-NL: AHOB</li>
</ul>
This value may be specialised in the national domain (see e.g. DB domain).""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystemProperty> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment> a owl:Class ;
    rdfs:label "TrafficMoment" ;
    rdfs:comment """Traffic volume for which the crossing is designed.
The number results from a nationally regulated formula that can include both rail and road traffic.
The calculation documents can be stored in an attachment.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#peak> ;
            owl:someValuesFrom xsd:decimal ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#average> ;
            owl:someValuesFrom xsd:decimal ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#BarrierMechanism>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#ClearanceDetector>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#DangerArea>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#DangerAreaTrack>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivationDelaySet>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingClearanceDetectionSystem>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingControllerFailureReporting>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingDeactivation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingLocalOperationUiElement>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingRouteRelation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSignalRelation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingTimerSet>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RadarReflector>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficSign>,

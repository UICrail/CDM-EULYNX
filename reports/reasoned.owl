        <rdfs:comment>A logical boolean input or output communication channel.</rdfs:comment>
        <rdfs:label>LogicalChannel</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#LogicalInputChannel -->


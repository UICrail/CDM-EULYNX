    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#TC69_StationPlatforms -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#TC69_StationPlatforms">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTrackConditionMarker"/>

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#ControlRelation> a owl:Class ;
    rdfs:label "ControlRelation" ;
    rdfs:comment """Association class informing about the control relation between two controllers or between a controller and a controlled track asset.
End point A and B in combination with the navigability inform about the direction of the flow.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#ControlArea> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#Lock> a owl:Class ;
    rdfs:label "Lock" ;
    rdfs:comment "The lock accepts a key and locks out one or more track assets from interlocking control.",
        """captiveKey
True: the key is normally in.
False: the key is normally out.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#captiveKey> ;
            owl:someValuesFrom xsd:boolean ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#acceptsKey> ;

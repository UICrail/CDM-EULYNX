                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#name_SimpleDesignation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>SimpleDesignation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SourceInformation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SourceInformation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfigurationProperty"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#source"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SupplierInformation"/>
        <rdfs:comment>Information about the source of the data.</rdfs:comment>
        <rdfs:label>SourceInformation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SupplierInformation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SupplierInformation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfigurationProperty"/>
        <rdfs:label>SupplierInformation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#TrackLubricator -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#TrackLubricator">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideSpotSystem"/>
        <rdfs:label>TrackLubricator</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Tunnel -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Tunnel">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideLinearConstruction"/>
        <rdfs:label>Tunnel</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#TunnelTube -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#TunnelTube">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideLinearConstruction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#belongsToTunnel"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Tunnel"/>

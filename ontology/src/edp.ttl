<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Actor> a owl:Class ;
    rdfs:label "Actor" ;
    rdfs:comment """A party, typically a person and his/her contact data, who participates in the planning creation process.
The fields can be filled as far as privacy rules allow. For instance, NR only uses initials on plans, while SCNF requires full name and initials.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#TimeFrame> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#StatusInformation> a owl:Class ;
    rdfs:label "StatusInformation" ;
    rdfs:comment """The status that the actor achieved at the given stage.
The status reflects the actor's role in the business process;
Typical states are: designed, checked, approved.

The status information is like an entry in the amendment log that accompanies legacy paper plans.
E.q.  "quality checked on 2024/6/30 by A.M." or
"data set initial creation by B.J. on 2021/9/8\"""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#dateProcessStepAchieved> ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#isDocumentedInAttachment> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Attachment> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#statusName> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Actor>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectMetaData>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#TimeFrame> .

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#DataPrepEntities> a owl:Class ;
    rdfs:label "DataPrepEntities" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsTrafficFlow> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#TrafficFlow> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsSwitchGear> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Traction_power_supply#SwitchGear> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsFloodlight> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Assets/Level_crossing#Floodlight> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#hasPowerLineCrossing> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Traction_power_supply#PowerLineCrossing> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsWeldedStrip> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Assets/Train_detection#WeldedStrip> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsPointHandle> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Assets/Point_crossing_derailer#PointHandle> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsSequenceMonitor> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Automatic_route_setting#SequenceMonitor> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsRailNodePath> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#RailNodePath> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsBoosterTransformer> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Traction_power_supply#Transformer> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsGate> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Assets/Level_crossing#Gate> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsTimingPoint> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#TimingPoint> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsSpadAlarm> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Automatic_route_setting#SpadAlarm> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Data_container#ownsTractionFeed> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Traction_power_supply#TractionFeed> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Data_container#DataPrepEntities> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Block_system#LineBlockInformation> a owl:Class ;
    rdfs:label "LineBlockInformation" ;
    rdfs:comment "Set of general attributes for the block line, viewed from a station." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Block_system#BlockElement>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Block_system#BlockSystem> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#IpAddressAssignment> a owl:Class ;
    rdfs:label "IpAddressAssignment" ;
    rdfs:comment "A collection of blocks of addresses that is assigned to equipment that communicates over IP.",
        """region
The region that governs the set of IP- addresses that may be used.
Not given if irrelevant.
de-DE: Regionalbereich wo sich der Controller befindet.""",
        """subsystem
The subsystem for which the addresses are reserved.
E.g. MDM, ancillary equipment. 
In early design one can state placeholders for subsystems that will be defined later, e.g. RBC.
Not provided if irrelevant.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#includesIpInformation> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#IpAddressBlock> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#ControlArea>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#ControlRelation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#ControlledTrackAsset> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#BarrierBoom> a owl:Class ;
    rdfs:label "BarrierBoom" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#isOrientedNormal_BarrierBoom> ;
            owl:someValuesFrom xsd:boolean ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#FailureReport>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#StAndrewsCross> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingLocalOperationUiElement> a owl:Class ;
    rdfs:label "LevelCrossingLocalOperationUiElement" ;
    rdfs:comment """A component of the user interface for local operation of a level crossing, e.g. button, lever, switch.
The intended function is given by specialisation in the national domains or by description (of ConfiguredBaseObject).""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#appliesToLocalOperationUiElement_LevelCrossingLocalOperationUiElement> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiElement> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#ClearanceDetector>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#DangerAreaTrack>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivationDelaySet>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingClearanceDetectionSystem>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingControllerFailureReporting>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingDeactivation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingRouteRelation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSignalRelation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingTimerSet>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RadarReflector> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RadarReflector> a owl:Class ;
    rdfs:label "RadarReflector" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#ClearanceDetector>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#DangerAreaTrack>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivationDelaySet>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingClearanceDetectionSystem>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingControllerFailureReporting>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingDeactivation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingRouteRelation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSignalRelation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingTimerSet> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#LightSignal> a owl:Class ;
    rdfs:label "LightSignal" ;
    rdfs:comment """isIntentionallyDarkAllowed
The line-side system can switch the light signal to intentionally dark when a cab signalling ATP system such as LZB or ETCS is leading. 
The signal lamps are intentionally turned off and the driver disregards the light signal.
This avoids conflict between line-side aspect and cab aspect in dual signalling environments.

Not to be used when a signal is switched to a special aspect (white lamp or white cross), indicating that the signal should be disregarded. The other signal lamps are dark but this is not meant by intentionally dark.

Notes on dark signals:
<ul>
	<li>A light signal that is dark because it has failed represents danger.</li>
	<li>In the UK, dark mode applies to LX warning light that switch to dark on purpose, e.g. a failed level crossing in the UK because a permanent warning light invites undesirable behaviour by motorists.</li>
</ul>""",
        """isTunnelSignal
Signal placed in tunnels, typically used to indicate special fixing requirements and/or light intensity.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#ActiveSignal> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessageRelation> a owl:Class ;
    rdfs:label "SignalMessageRelation" ;
    rdfs:comment """A signal-message relation is composed of two pairs master(signal,message) and dependent(signal,message).
The message of the master signal dictates the message of the dependent signal.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#hasDependentMessage> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#hasMasterMessage> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#PointElementAndPosition> a owl:Class ;
    rdfs:label "PointElementAndPosition" ;
    rdfs:comment """A pair (point element, position).

The point element is the movable part of a point and no model class strictly speaking.

The positions that a point can adopt are left or right. Three-way points are rare and modelled as two consecutive points.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inPosition_PointElementAndPosition> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableElementAndPosition> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage> a owl:Class ;
    rdfs:label "SignalAndMessage" ;
    rdfs:comment """A pair (signal, message). 
When instantiated, this provides a list of all possible (signal, message) pairs needed for constructing signal plans. Pairs that are not in the list are disallowed.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#showsMessage> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessage> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#appliesToSignal_SignalAndMessage> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRouteTrigger> a owl:Class ;
    rdfs:label "ArsRouteTrigger" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#refersToDistantSignal> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ownsSpeedDependentDelay> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsSpeedCategory> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRoute> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsProgrammingFileSet> a owl:Class ;
    rdfs:label "EtcsProgrammingFileSet" ;
    rdfs:comment """Set of binary data files that are used for programming electronic equipment such as balises or LEU.
A set of load and auxiliary files.
de-DE: Programmierdateigruppe.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#BaliseGroupFunction>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#BinaryDataFile>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsAcknowledgement>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsMaSection>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTelegram>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTelegramConditionRelation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#LtProperties> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsSignalProperties> a owl:Class ;
    rdfs:label "EtcsSignalProperties" ;
    rdfs:comment "Set of properties that apply to an ETCS signal.",
        """acceptsRbcCommand
True if the light signal accepts a command from the interlocking to switch on the aspect dedicated to ETCS-guided trains.""",
        """isEtcsEntry
True if this signal is inside the ETCS L2 area and can be used for Level 2 Start of Mission.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#isEtcsEntry> ;
            owl:someValuesFrom xsd:boolean ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#appliesToSignal_EtcsSignalProperties> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#BaliseGroupProperty>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#CantDeficiencySpeed>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsDangerpoint>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsEndOfAuthority>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsLevelCondition>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsNationalValuePair>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsPacket>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsSrsVersion>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTextDisplayEndCondition>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTextDisplayStartCondition>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTrainCategorySpeed>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#FileProperties>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#LeuCabinetLocation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#LeuPort>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#StandstillDetectionForShunting> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTextMessageMarker> a owl:Class ;
    rdfs:label "EtcsTextMessageMarker" ;
    rdfs:comment """Marks a <i>spot location</i> from where a text message to the train applies.
The text message is displayed under the given condition, inherited from TP marker, e.g. only when a set of points are in the given position. 
If no condition is given, the text message display is governed only by ETCS variables D/L_TEXTDISPLAY.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#text_EtcsTextMessageMarker> ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#l_text> ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#nid_c_EtcsTextMessageMarker> ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#q_text> ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#q_conftextdisplay> ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#q_textdisplay> ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#nid_textmessage> ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#q_textconfirm> ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#nid_rbc_EtcsTextMessageMarker> ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#q_textclass> ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#hasDisplayEndCondition> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTextDisplayEndCondition> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#q_textreport> ;
            owl:someValuesFrom xsd:integer ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsMarker> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#RouteCondition> a owl:Class ;
    rdfs:label "RouteCondition" ;
    rdfs:comment """A route condition states the conditions that must be fulfilled for a given signal <i>or </i>route to open.
If the track asset or compound logical object<font color="#ff0000"> </font><i>is in the given state then </i>the signal in this route relation is set to proceed or to the given aspect. The routeRelation is the <i>observer </i>of the aspect and its state.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointUnionOf ( <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#ConditionAffectingRoute> <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#ConditionAffectingSignal> ) ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#ConflictingRoute>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#RouteBody> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#LockoutArea> a owl:Class ;
    rdfs:label "LockoutArea" ;
    rdfs:comment "Area under temporary possession, typically for maintenance activities." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningSystem> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SourceInformation> a owl:Class ;
    rdfs:label "SourceInformation" ;
    rdfs:comment "Information about the source of the data." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#source> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfigurationProperty> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Data_container#DataContainer> a owl:Class ;
    rdfs:label "DataContainer" ;
    rdfs:comment "Container for a structured data set that describes the state of signalling assets in a data release." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Data_container#hasExplanatoryNote> ;

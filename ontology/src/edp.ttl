<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsRelation> a owl:Class ;
    rdfs:label "TpsRelation" ;
    rdfs:comment """Informs at what distance the TP device or system is placed on approach to the signal. 
The signal could be a speed restriction board (NR approach).""" ;

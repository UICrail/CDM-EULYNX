<https://cdm.ovh/edp> a owl:Ontology ;
    dc:creator "Airy Magnien" ;
    dc:date "9 May 2026" ;
    dc:description "Eulynx Dataprep, adapted to Semantic RSM" ;
    dc:title "Eulynx Dataprep 1.2" ;
    dcterms:license "EUPL 1.2" ;
    rdfs:comment "Possibly with some further changes, e.g. using QUDT." ;
    owl:imports <https://cdm.ovh/rsm/linearReferencing/rlrs>,
        <https://cdm.ovh/rsm/localisation/loca>,
        <https://cdm.ovh/rsm/topology/topo>,
        <https://cdm.ovh/rsm/track/trfn> .

<https://cdm.ovh/edp/EULYNX_DataPrep> a owl:Ontology ;
    rdfs:comment "UML/XMI→OWL transformation (lossy; no provenance)." .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic> a owl:Ontology ;
    rdfs:comment "UML/XMI→OWL transformation (lossy; no provenance)." .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common> a owl:Ontology ;
    rdfs:comment "UML/XMI→OWL transformation (lossy; no provenance)." .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#EulynxOperationalIdentifier> a owl:Class ;
    rdfs:label "EulynxOperationalIdentifier" ;
    rdfs:comment """The name attribute identifies an operational element that is controlled by a EULYNX subsystem or adjacent system.

The name is a string that consists of 20 characters, ISO IEC 8859-1:1998 left justified, empty spaced to be filled with underscore (0x5F).""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SimpleDesignation> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#EulynxPayloadIdentifier> a owl:Class ;
    rdfs:label "EulynxPayloadIdentifier" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SimpleDesignation> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ForFutureUse> a owl:Class ;
    rdfs:label "ForFutureUse" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OutOfService> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OutOfServicebyInstructionOnly> a owl:Class ;
    rdfs:label "OutOfServicebyInstructionOnly" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OutOfService> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#PullWire> a owl:Class ;
    rdfs:label "PullWire" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideDetector> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#TrackLubricator> a owl:Class ;
    rdfs:label "TrackLubricator" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideSpotSystem> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#appliesToBaselineOfRuleSet> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Configuration> ;
    rdfs:range <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaselineOfRuleSet> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#appliesToLineSideDetectionSystem> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideDetector> ;
    rdfs:range <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideDetectionEvaluator> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#appliesToLinearElement> a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:domain <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Edge> ;
    rdfs:range xsd:string .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#appliesToTrackCrossing_MappingView> a owl:FunctionalProperty,

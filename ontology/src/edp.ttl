<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Assets/Train_detection#DerailmentDetector> a owl:Class ;
    rdfs:label "DerailmentDetector" ;
    rdfs:comment """The associated track section is occupied when interrupter is activated/broken (only placed in derailer section; detects a train even if it is not on the rails anymore)
Can be associated with a buffer stop that constrains the position of the derailment detector.
Also known as track circuit interruptor.""",
        """repeated
True: the detector is hard-wired to the track circuit occupancy.
False: relay-based detection so that the derailment signal can be relayed for other functions.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Assets/Train_detection#repeated> ;
            owl:someValuesFrom xsd:boolean ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor> .


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#AdditionalInformation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#AdditionalInformation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfigurationProperty"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#text_AdditionalInformation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ControlCode"/>

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#InterlockingIntegratedLevelCrossing> a owl:Class ;
    rdfs:label "InterlockingIntegratedLevelCrossing" ;
    rdfs:comment "A level crossing that is directly controlled by the interlocking (LC system)." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#IntegratedLevelCrossing> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LocallyMonitoredLevelCrossing> a owl:Class ;
    rdfs:label "LocallyMonitoredLevelCrossing" ;
    rdfs:comment """A level crossing system that is locally monitored by the train driver: The driver observes a signal that indicates the crossing working order. 
Failure and health status are optionally monitored and transmitted to an (unspecified) system (other than the IL logic).""",
        "The difference is that the interlocking logic uses I/O from the self-supervised level crossing, but does not use I/O from the locally-monitored level crossing." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystem> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformRoof> a owl:Class ;
    rdfs:label "PlatformRoof" ;
    rdfs:comment "Platform roof, insofar relevant to signalling concerns such as signal fixation, obscuration and train stopping location." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isLocatedAt_PlatformRoof> ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#appliesToPlatformEdge_PlatformRoof> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformFacility> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Crossing> a owl:Class ;
    rdfs:label "Crossing" ;
    rdfs:comment """Installation where tracks intersect.
Some crossings, especially high speed ones, have a switched diamond to close the gap at the crossing (de-DE: Flachkreuzung mit beweglichen Herzst&#252;ckspitzen, nl-NL: kruising met beweegbaar puntstuk). 
The slip points to which the crossing connects, if any, are separate instances of the Point class.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#refersToRsmCrossing> ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#hasDiamond> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Diamond> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointCrossing> .


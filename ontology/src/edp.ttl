    rdfs:label "ElectrificationGap" ;
    rdfs:comment """Gap in the traction system where no traction power can ever be drawn.
en-UK: neutral section in overhead line systems, gap in third rail systems.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSegment> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SynchedFlashing> a owl:Class ;
    rdfs:label "SynchedFlashing" ;

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Mechanism> a owl:Class ;
    rdfs:label "Mechanism" ;
    rdfs:comment "A mechanism designed to drive and/or detect movable components." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset> ;
    owl:disjointUnionOf ( <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#HandOperated> <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Mechanical> <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointMachine> ) ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponent>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointCrossingElementConfiguration> a owl:Class ;
    rdfs:label "PointCrossingElementConfiguration" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#canReportTrailed> ;
            owl:someValuesFrom xsd:boolean ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElementConfiguration> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#scheme_ControlModes_EAID_6F17E12A_D058_47ff_8FEC_C285BA484711> a skos:ConceptScheme ;
    rdfs:label "ControlModes" ;
    rdfs:comment "The mode in which the movable element shall be controlled. See the enumeration <i>MechanismTypes </i>for choices of the types of mechanism that actually drive the movable components.",
        """local
The element is operated on site by means of a nearby control panel or lever (en-UK: ground frame).""",
        """remote
An interlocking normally controls the element, even when the element can be taken over for local working e.g. shunting.""" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#scheme_MechanismTypes_EAID_81F76E0C_713C_4d1a_9BDE_3F549BA808D6> a skos:ConceptScheme ;
    rdfs:label "MechanismTypes" ;
    rdfs:comment """handOperated
Local manual operation by hand-pulled levers. Forces can be transmitted by rods but over a short distance. When forces are transmitted over longer wires and rods, powering is considered mechanical.""",
        """mechanical
Power is transmitted via wires or bars over larger distances.""" .


        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#hasValidationChannel_DoubleLogicalOutputChannel> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#PhysicalOutputChannel> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#LogicalOutputChannel> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#scheme_InputChannelType_EAID_1FBACF2F_A65E_4c64_BE16_407EC37536A5> a skos:ConceptScheme ;
    rdfs:label "InputChannelType" .


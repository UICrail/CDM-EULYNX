<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#DerailerElementAndPosition> a owl:Class ;
    rdfs:label "DerailerElementAndPosition" ;
    rdfs:comment """A pair (derailer element, position).

The derailer element is the movable part of a derailer and no model class strictly speaking.

Used for expressing concepts like: the derailer has to be in the non-derailing position.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inPosition_DerailerElementAndPosition> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableElementAndPosition> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SectionAndVacancy> a owl:Class ;
    rdfs:label "SectionAndVacancy" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inVacancyState> ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#refersToTdsSection> ;

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RouteSetupTime> a owl:Class ;
    rdfs:label "RouteSetupTime" ;
    rdfs:comment """The typical delay between the moment the operator calls this route and the moment the entry signal opens. 
This  parameter includes the response-time of many subsystems as well as point throwing time (the position of which is often unknown beforehand). This parameter is by nature stochastic.
This parameter is useful for simulation purposes and system performance analysis.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#hasSetupTime> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RouteProperty> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#AutoRoute>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RouteAvailableInARS>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RoutePriority>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RouteSpeedRestriction> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#DirectionAuthorityDependentOverlap> a owl:Class ;
    rdfs:label "DirectionAuthorityDependentOverlap" ;
    rdfs:comment "The overlap can only be activated when the block accepts the direction in which the route and thus the overlap are set." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#appliesToBlockElement> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Block_system#BlockElement> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#appliesToOverlap_DirectionAuthorityDependentOverlap> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#Overlap> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#SwingingOverlap> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#SwingingOverlap> a owl:Class ;
    rdfs:label "SwingingOverlap" ;
    rdfs:comment """An overlap section may, even though locked, be swung away from a conflicting route to provide a full-length overlap (source: INESS)
The swinging overlap typically contains a facing point (de-DE: Ruderweiche). This implies that 
<ol>
	<li>there are two possible overlaps associated with the closed exit signal and</li>
	<li>the signaller can swing the overlap between left and right (normal and reverse).</li>
</ol>
The swinging overlap must point to two limiting train detectors.
National rules and regulations govern when and how the facing point(s) can be thrown.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#appliesToOverlap_SwingingOverlap> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#Overlap> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#Balise> a owl:Class ;
    rdfs:label "Balise" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsSpotDevice> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningArea> a owl:Class ;
    rdfs:label "WarningArea" ;
    rdfs:comment """The area fitted with a warning system that alerts line-side staff about impending danger.
The area can have a designation, name and other configuration items.""" ;

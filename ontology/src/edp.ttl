    rdfs:comment """Type of protection. 
E.g.
<ul>
	<li>half-barrier</li>
	<li>full-barrier</li>
	<li>user-worked crossing with telephone</li>
</ul>""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystemProperty> .


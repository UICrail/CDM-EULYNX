<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#ControlledTrackAsset> a owl:Class ;
    rdfs:label "ControlledTrackAsset" ;
    rdfs:comment """Controlled track assets are the subset of track assets that 
<ul>
	<li>are <b>controlled </b>by, and/or</li>
	<li>are <b>powered </b>by, and/or</li>
	<li><b>exchange </b>information with a controller.</li>
</ul>
There has to be one instance of this class for each associated track asset instance.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#getsBackupPowerFrom> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#ControlArea>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#ControlRelation> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_standard_interfaces#RastaEndPoint> a owl:Class ;
    rdfs:label "RastaEndPoint" ;
    rdfs:comment "End point of a RaSTA communication channel." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge> a owl:Class ;
    rdfs:label "PlatformEdge" ;
    rdfs:comment """Part of the platform facility adjacent to a track.
The designation of the platform edge is for passenger information systems, typically a number plus a letter e.g. <i>platform 6</i> or <i>platform 10a/b</i>.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#hasProperty_PlatformEdge> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdgeProperty> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isLocatedAt_PlatformEdge> ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#hasDispatchPosition> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#DispatchPosition> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset> ;
    owl:disjointUnionOf ( <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#OperationalPlatformEdge> <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#UsablePlatformEdge> <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#InfrastructuralPlatformEdge> ) ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformFacility> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#Aspect> a owl:Class ;
    rdfs:label "Aspect" ;
    rdfs:comment """Atomic information displayed by the signal, conveyed by means of light, shape, text, symbol, form, colour.
de-DE: Signalbegriff""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#aspectId> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessageRelation> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#scheme_FixingTypes_EAID_D96C7573_FF55_43ca_81BD_DA5FED5DE012> a skos:ConceptScheme ;
    rdfs:label "FixingTypes" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSection> a owl:Class ;
    rdfs:label "TdsSection" ;
    rdfs:comment """A logical section of the train detection system.
The section is associated with a TVP section.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#appliesToTvpSection_TdsSection> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TvpSection> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#VirtualTrackAsset> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TvpSection> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TriggerAssignment> a owl:Class ;
    rdfs:label "TriggerAssignment" ;
    rdfs:comment """Assigns a trigger to vehicle detection.
The trigger is typically a Vehicle Passage Detector. It can also be an approach zone, either all sections or only the extremity. Even if no train detection is given, a condition can still apply.
NR: strike-in or strike-out; the trigger is closely associated with vehicle detection""",
        """functionDescription
Describes the triggering action, e.g. <i> "Activate the level crossing at km x.y"</i>. The description is subject to national rules and regulations.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsOccupancyOverrideGroup> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTelegramConditionRelation> a owl:Class ;
    rdfs:label "EtcsTelegramConditionRelation" ;
    rdfs:comment """A set of telegrams that is sent under the given set of conditions applies.
Used for switchable balises.

The SRS versions allows selecting telegrams of a given version.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#sentConditionally> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#Condition> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#StandstillDetectionForShunting> a owl:Class ;
    rdfs:label "StandstillDetectionForShunting" ;
    rdfs:comment "A timer for measuring the time a train has been stationary before entering the temporary shunting area." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#hasStandstillTimer> ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#appliestoTempShuntingArea> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Local_operating_area#LocalOperatingArea> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsSrsVersion> .

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Assets/Level_crossing#scheme_LevelCrossingControlTypes_EAID_7DE11D26_EFA8_4f85_8DAB_473ADE8CD223> a skos:ConceptScheme ;
    rdfs:label "LevelCrossingControlTypes" .

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#scheme_KvbCsspInformationTypes_EAID_CF8E6DBE_2477_44fe_BBF4_A1D039851FB7> a skos:ConceptScheme ;
    rdfs:label "KvbCsspInformationTypes" ;
    rdfs:comment """Enumeration of values for the information field of the CSSP family not linked to speed control and various functions.

fr-FR: Abr&#233;viations de la d&#233;signation des champs de la famille CSSP <i>non </i>li&#233;s au contr&#244;le de vitesse et fonctions diverses.

Source: SNCF document IG90169, paragraph 6.3.3""" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingClearanceDetectionSystem> a owl:Class ;
    rdfs:label "LevelCrossingClearanceDetectionSystem" ;
    rdfs:comment """A system that detects the absence of obstacles in the level crossing danger area.
The installation- and setup manuals can be attached or referred from this class.
An acceptance certificate is implied in the supplier information (OEM product name which is part of the supplier configuration property).
de-DE: Gefahrraumfreimeldeanlage
en-GB: crossing clear function""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#hasObstacleDetector_LevelCrossingClearanceDetectionSystem> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#ClearanceDetector> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#appliesToLevelCrossingSystem_LevelCrossingClearanceDetectionSystem> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystem> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingControllerFailureReporting> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsDangerpoint> a owl:Class ;
    rdfs:label "EtcsDangerpoint" ;
    rdfs:comment "Marks the spot beyond the EoA up to where a train can advance without danger." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#isAtLocationProxy> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationProxy> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#releaseSpeedInstruction_EtcsDangerpoint> ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#hasAllowedTrainCategorySpeed_EtcsDangerpoint> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTrainCategorySpeed> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsEndOfAuthority>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsSrsVersion>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#StandstillDetectionForShunting> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsMaSection> a owl:Class ;
    rdfs:label "EtcsMaSection" ;
    rdfs:comment """The ETCS Movement Authority (MA) section.
ETCS variable D_SECTIONTIMERSTOPLOC is the distance between start and stop location.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#hasSectionEntryLocation> ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#t_sectiontimer> ;
            owl:someValuesFrom xsd:integer ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTelegramConditionRelation> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsNationalValuePair> a owl:Class ;
    rdfs:label "EtcsNationalValuePair" ;
    rdfs:comment "A  pair of a <i>key (i.e. </i>the name of the National Value) and its <i>value.</i>" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#key_EtcsNationalValuePair> ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#hasSubset> ;

    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#scheme_ControlModes_EAID_6F17E12A_D058_47ff_8FEC_C285BA484711 -->

    <owl:NamedIndividual rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#scheme_ControlModes_EAID_6F17E12A_D058_47ff_8FEC_C285BA484711">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:comment>The mode in which the movable element shall be controlled. See the enumeration &lt;i&gt;MechanismTypes &lt;/i&gt;for choices of the types of mechanism that actually drive the movable components.</rdfs:comment>
        <rdfs:comment>local
The element is operated on site by means of a nearby control panel or lever (en-UK: ground frame).</rdfs:comment>
        <rdfs:comment>remote
An interlocking normally controls the element, even when the element can be taken over for local working e.g. shunting.</rdfs:comment>
        <rdfs:label>ControlModes</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#scheme_DiamondComponentSide_EAID_E5388E22_FAF9_4e37_8A60_7D5BC97349A6 -->

    <owl:NamedIndividual rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#scheme_DiamondComponentSide_EAID_E5388E22_FAF9_4e37_8A60_7D5BC97349A6">

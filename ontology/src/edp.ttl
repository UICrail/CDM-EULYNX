        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#StoppingPoint> a owl:Class ;
    rdfs:label "StoppingPoint" ;
    rdfs:comment "The operational train stopping point." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isLocatedAt_StoppingPoint> ;

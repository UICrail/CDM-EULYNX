        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Traction_power_supply#connectsAt"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The transformer typically is located inside an &lt;a href=&quot;$element://{4CAA34FD-50C5-4575-AC2D-B86AB3ECE659}&quot;&gt;&lt;font color=&quot;#0000ff&quot;&gt;&lt;u&gt;electrification gap&lt;/u&gt;&lt;/font&gt;&lt;/a&gt; where stopping is disallowed.</rdfs:comment>
        <rdfs:label>Transformer</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Train_protection#ApcMagnet -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Train_protection#ApcMagnet">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsSpotDevice"/>

            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#nc_diff> ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#v_diff_EtcsTrainCategorySpeed> ;
            owl:someValuesFrom xsd:integer ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsDangerpoint>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsEndOfAuthority>,

            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>KvbTrain</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#PassengerTrain -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#PassengerTrain">

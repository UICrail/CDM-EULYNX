    owl:disjointUnionOf ( <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#ExternalDetector> <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointDrive> ) .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#scheme_MovableElementOperatingModes_EAID_6A4BFB11_F9C7_4729_9426_7F355529DA48> a skos:ConceptScheme ;
    rdfs:label "MovableElementOperatingModes" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PhysicalPowerSupplyModule> a owl:Class ;
    rdfs:label "PhysicalPowerSupplyModule" ;
    rdfs:comment "A physical power supply field module." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#isHousedIn_PhysicalPowerSupplyModule> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PowerSupplyModule> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationOverlap> a owl:Class ;
    rdfs:label "ElectrificationOverlap" ;
    rdfs:comment """Section where overhead lines overlap. When a train stops in the overlap, chances are that current runs through and damages the pantograph. Trains should therefore not stop here. 
fr-FR: sectionnement critique
nl-NL: open spaninrichting.""",
        """type
Description of the type of overlap: booster, auto, traction mounted auxiliary, normally open/closed switch.
Used for assessing where to place signals to minimise the risk of trains stopping in the overlap.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSegment> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#FictitiousSignal> a owl:Class ;
    rdfs:label "FictitiousSignal" ;
    rdfs:comment """A software object in the interlocking. It may be visible on the signaller control display but not on the driver's DMI. Trains don't stop at a fictitious signal.
Also called cross-boundary signal (see <a href="$diagram://{91C01CCE-B70B-480e-9A87-4B436D3B4FD8}"><font color="#0000ff"><u>here</u></font></a>).""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#NonPhysicalSignal> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#SignalFrameComponent> a owl:Class ;
    rdfs:label "SignalFrameComponent" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#SignalFrame> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#DispatchAnnouncerAssignment> a owl:Class ;
    rdfs:label "DispatchAnnouncerAssignment" ;
    rdfs:comment """The entry signal is associated either with
<ul>
	<li>a light signal informing train staff to prepare for imminent departure (de-DE: Fahrtank&#252;nder - wei&#223;es Dreieck)</li>
	<li>a counter indicating the remaining time to planned departure (ProRail)</li>
</ul>
<ul>
	<li>a system that messages the train staff mobile device (de-DE: dann entf&#228;llt der physische Fahrtank&#252;nder).</li>
</ul>""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroup>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignment>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalPlan>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalSightingDistance> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignmentPointOnTrack> a owl:Class ;
    rdfs:label "SignalAlignmentPointOnTrack" ;
    rdfs:comment """The signal must be aligned such that the driver can see it. This class describes the position (upstream on the track) of the target of the signal: distance, and optionally height.
This information is typically checked during the installation and testing phases.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#distance> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignment> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalType> a owl:Class ;
    rdfs:label "SignalType" ;
    rdfs:comment """General class for describing the signal type. National types can be described in the national domains. 
For instance: signal head type as defined by NR.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#SignalLocation> a owl:Class ;
    rdfs:label "SignalLocation" ;
    rdfs:comment """Description of the area where the signal is located, to help maintenance workers to find the signal in the field.
Can be an informal description (e.g. near junction x) or depend on national regulations (e.g. DE Bezeichnung nach Ril 100).""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#description_SignalLocation> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#CompoundLogicalObjectAndState> a owl:Class ;
    rdfs:label "CompoundLogicalObjectAndState" ;
    rdfs:comment "A pair (Compound Logical Object, boolean).",
        """HighOrLow
High equates to 1=true means safe for train passage.
Low equates to 0=false means unsafe for train passage.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#refersToCompoundLogicalObject> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#CompoundLogicalObject> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#HighOrLow> ;
            owl:someValuesFrom xsd:boolean ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#LevelCrossingAndState> a owl:Class ;

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Friction> a owl:Class ;
    rdfs:label "Friction" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#coefficient> ;
            owl:someValuesFrom xsd:decimal ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RestrictedArea>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialGauge>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackDesignation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#MainTrack> a owl:Class ;
    rdfs:label "MainTrack" ;
    rdfs:comment """Main track in a station under control of an interlocking <i>as opposed to </i>open line.
NR: Passengerline, thick line on drawing""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SandHump> a owl:Class ;
    rdfs:label "SandHump" ;
    rdfs:comment """A sand hump, drag or other pile of sand designed to stop an overrunning vehicle.
Do not use the attribute isOfVehicleStopType when using sand hump.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#VehicleStop> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SlabTrack> a owl:Class ;
    rdfs:label "SlabTrack" ;
    rdfs:comment """Concrete, ballastless track bed.
de-DE: feste Fahrbahn""",
        """isFloating
The concrete slab to which the rails are affixed is supported by a flexible layer that attenuates elastic waves.
Need not to be filled in if irrelevant to signalling or unknown.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SleeperTrack> a owl:Class ;
    rdfs:label "SleeperTrack" ;
    rdfs:comment "Track with sleepers resting on ballast." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#hasSleepersMadeOf> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway> .


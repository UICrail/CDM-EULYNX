<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ObjectStatus> a owl:Class ;
    rdfs:label "ObjectStatus" ;
    rdfs:comment """An object-configuration can reflect a particular status, typically in construction phases.
For instance, a signal can be disconnected so drivers disregard the signal. The signal would then own a configuration associated with an out-of-service status.
This abstract class reflects an object status and the IM can specialise the object status that describes national needs.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#isInFunctionalPosition> ;
            owl:someValuesFrom xsd:boolean ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#isControlled> ;
            owl:someValuesFrom xsd:boolean ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfigurationProperty> ;
    owl:disjointUnionOf ( <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#CoveredObject> <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#DummyMode> <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OutOfService> <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OtherObjectStatus> ) ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SourceInformation> .


        <rdfs:comment>Defines the types of equipment location.</rdfs:comment>
        <rdfs:label>EquipmentLocation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#FullDesignation -->


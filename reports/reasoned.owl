        <rdfs:comment>Controller of the ATB VV system, housed in an ASK cabinet.</rdfs:comment>
        <rdfs:label>AtbVvController</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbVvInstallation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbVvInstallation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDataTransmissionSystem"/>
        <rdfs:comment>Installation consisting of ATB VV beacons (transponders) and an optional loop.</rdfs:comment>
        <rdfs:label>AtbVvInstallation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbVvLoop -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbVvLoop">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbLoop"/>
        <rdfs:label>AtbVvLoop</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Working_safety#PermanentWarningSystem -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Working_safety#PermanentWarningSystem">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#PermanentWarningSystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Working_safety#isOfType_PermanentWarningSystem"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Permanent installation for warning line-side staff. 
nl-NL: vaste waarschuwingsinstallatie</rdfs:comment>
        <rdfs:label>PermanentWarningSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Working_safety#TriggerAssignmentWithDelay -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Working_safety#TriggerAssignmentWithDelay">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TriggerAssignment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Working_safety#hasDelay"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The given signal is cleared/closed when the warning system is triggered &lt;i&gt;and&lt;/i&gt; after the delay expires.
Not used for LC warning (use &lt;a href=&quot;$element://{E6CD35A8-D498-4cf6-9818-716CD127386D}&quot;&gt;&lt;font color=&quot;#0000ff&quot;&gt;&lt;u&gt;this&lt;/u&gt;&lt;/font&gt;&lt;/a&gt; instead).
nl-NL: seinvertraging wordt door de eigenschappen van de waarschuwingsinstallatie bepaald zoals rijtijd plus marge.</rdfs:comment>
        <rdfs:label>TriggerAssignmentWithDelay</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Assets/Signal#LensDiffuser -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Assets/Signal#LensDiffuser">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#LensDiffuser"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Assets/Signal#isOfLensDiffuserType_LensDiffuser_Signal"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>LensDiffuser</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Assets/Signal#SignalAlignment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Assets/Signal#SignalAlignment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignmentPointOnTrack"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Assets/Signal#alpha"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>alpha
The angle in degrees between tangent to the track and signal target direction at a distance of 300m or less.</rdfs:comment>
        <rdfs:label>SignalAlignment</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Common#Designation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Common#Designation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Designation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Common#fullName_Designation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Common#number_Designation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Common#prefix_Designation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Italian track assets are labeled with a series
of strings: prefix + number + fullname 

it-IT: I track asset italiani sono etichettati con una serie di stringhe: 
prefisso + numero + nome completo 

E.g.  prefix=&quot;Savv&quot;,  number=&quot;03&quot;,  fullname=&quot;Savv03&quot;</rdfs:comment>
        <rdfs:label>Designation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Data_container#DataPrepEntities -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/RFI/Data_container#DataPrepEntities">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Data_container#DataPrepEntities"/>
        <rdfs:label>DataPrepEntities</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Assets/Signal#FictitiousSignal -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Assets/Signal#FictitiousSignal">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#FictitiousSignal"/>
        <rdfs:comment>French fictitious signal.
fr-FR: Signal fictif &amp;#224; la limite de poste. Permet de scinder un parcours allant d&apos;un poste vers un autre en deux itin&amp;#233;raires compl&amp;#232;tement distincts, limitant ainsi au maximum les d&amp;#233;pendances entre les deux postes.</rdfs:comment>
        <rdfs:label>FictitiousSignal</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Automatic_route_setting#ArsRouteTrigger -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Automatic_route_setting#ArsRouteTrigger">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRouteTrigger"/>
        <rdfs:comment>fr-FR: Zone de demande (ZDE)</rdfs:comment>
        <rdfs:label>ArsRouteTrigger</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Common#LineSideDetectionEvaluator -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Common#LineSideDetectionEvaluator">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideDetectionEvaluator"/>
        <rdfs:comment>fr-FR: D&amp;#233;tecteur associ&amp;#233; &amp;#224; une ou plusieurs voies. La vitesse des voies sera r&amp;#233;duite, principalement en cas de d&amp;#233;tection de boite chaude.</rdfs:comment>
        <rdfs:label>LineSideDetectionEvaluator</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Data_container#DataPrepEntities -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Data_container#DataPrepEntities">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Data_container#DataPrepEntities"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Data_container#ownsOpposingRoute"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#OpposingRouteLocking"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Data_container#ownsTransit"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Transit_EAID_ACED038E_2CE8_4f0d_BB9E_FD9C5E14F957"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>DataPrepEntities</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#BidirectionalRouteLocking -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#BidirectionalRouteLocking">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#OpposingRouteLocking"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#checksTransit_BidirectionalRouteLocking"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Transit_EAID_ACED038E_2CE8_4f0d_BB9E_FD9C5E14F957"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Opposing route locking for routes in areas with points.
fr-FR: Enclenchement de parcours banalis&amp;#233; (dans les zones &amp;#233;quip&amp;#233;es d&apos;appareils de voie).
Les conditions d&apos;&amp;#233;tablissement de l&apos;itin&amp;#233;raire ne requi&amp;#232;rent que la v&amp;#233;rification du transit de sens contraire en aval du signal origine de l&apos;itin&amp;#233;raire (e.g. pour v&amp;#233;rifier qu&apos;aucun intin&amp;#233;raire de sens contraire form&amp;#233; a pour destination un signal en amont du signal origine).</rdfs:comment>
        <rdfs:label>BidirectionalRouteLocking</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#DirectionLocking -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#DirectionLocking">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#hasInterval_DirectionLocking"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Interval_EAID_FE95BDFD_02BE_415c_A7AE_A02DD147121E"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>fr-FR: Enclenchement de sens entre postes.
Checks to prevent simultaneous opening of opposing signals that are controlled by different interlocking systems.</rdfs:comment>
        <rdfs:label>DirectionLocking</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Interval_EAID_FE95BDFD_02BE_415c_A7AE_A02DD147121E -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Interval_EAID_FE95BDFD_02BE_415c_A7AE_A02DD147121E">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TransitAndMovableElementPosition"/>
        <rdfs:comment>Track between two signals equipped with an interlocked direction.
fr-FR: Intervalle. Portion de voie entre 2 signaux munie d&apos;un enclenchement de sens.</rdfs:comment>
        <rdfs:label>Interval</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#IpcsLocking -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#IpcsLocking">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#hasInterval_IpcsLocking"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Interval_EAID_FE95BDFD_02BE_415c_A7AE_A02DD147121E"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Used in case of IPCS or ITCS installations.

fr-FR: Installations Permanentes ou Temporaires de Contresens.
IPCS est un enclenchement de sens modifi&amp;#233;.
Par d&amp;#233;faut, l&apos;intervalle est orient&amp;#233; dans le sens normal (les signaux de contre-sens sont &amp;#233;teints, sauf celui de sortie de l&apos;intervalle et son signal d&apos;annonce, les crocodiles des signaux de sens contraire sont non aliment&amp;#233;s, les annonces de PN ne fonctionnent que dans le sens normal, etc.).
Pour prendre le sens normal, IPCS fonctionne quasiment comme l&apos;enclenchement de sens sauf que l&apos;occupation de l&apos;intervalle n&apos;est pas v&amp;#233;rifi&amp;#233;e.
Pour prendre le contre-sens, IPCS fonctionne comme l&apos;enclenchement de sens (donc l&apos;occupation de l&apos;intervalle est v&amp;#233;rifi&amp;#233;e), mais cette prise de sens &amp;#224; des cons&amp;#233;quences sur la signalisation de l&apos;intervalle. A la prise du contre-sens, l&apos;intervalle s&apos;oriente en contre-sens (les signaux de contre-sens s&apos;allument, les crocodiles de sens normal sont non aliment&amp;#233;s, les crocodiles de contre-sens sont aliment&amp;#233;s, les annonces de PN ne fonctionnent que dans le contre-sens, etc.).
D&amp;#232;s que l&apos;intervalle n&apos;est plus occup&amp;#233; et qu&apos;il n&apos;y a plus d&apos;itin&amp;#233;raire vers l&apos;intervalle en contre-sens, l&apos;intervalle se r&amp;#233;oriente en sens normal.</rdfs:comment>
        <rdfs:label>IpcsLocking</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#OpposingRouteLocking -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#OpposingRouteLocking">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Transit_EAID_ACED038E_2CE8_4f0d_BB9E_FD9C5E14F957"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#BidirectionalRouteLocking"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking"/>
        </owl:disjointUnionOf>
        <rdfs:comment>Defines the configuration parameters needed to implement the exclusion of face-to-face movement.
The system proves that sections in between opposing signals are not claimed for movement in the opposite direction. A signal that provides entry to a route can only be opened when no opposing route is set.</rdfs:comment>
        <rdfs:label>OpposingRouteLocking</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#RouteBody -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#RouteBody">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#RouteBody"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#hasDirection_RouteBody"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>RouteBody</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#SingleTrackLocking -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#SingleTrackLocking">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#hasInterval_SingleTrackLocking"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Interval_EAID_FE95BDFD_02BE_415c_A7AE_A02DD147121E"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Used case of single track, i.e. the opposing routes are part of one yard controlled by a single interlocking.

fr-FR: Voie Unique (VU)
Une voie unique dans le poste est une portion de voie d&amp;#233;limit&amp;#233;e par deux signaux de sens contraire dos &amp;#224; dos. Est v&amp;#233;rifi&amp;#233; que le transit de sens contraire de la zone de la VU est lib&amp;#233;r&amp;#233;. Si c&apos;est le cas, le sens de la VU est pris et l&apos;itin&amp;#233;raire s&apos;&amp;#233;tablit.</rdfs:comment>
        <rdfs:label>SingleTrackLocking</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#StandoffLocking -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#StandoffLocking">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#manualReleasePossible"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>fr-FR: Enclenchement d&apos;affrontement.</rdfs:comment>
        <rdfs:label>StandoffLocking</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#StationTrackLocking -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#StationTrackLocking">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#hasInterval_StationTrackLocking"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Interval_EAID_FE95BDFD_02BE_415c_A7AE_A02DD147121E"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Allows shunting movement on track situated between the opposing signals.

fr-FR: enclenchement de voie de stationnement (St).
Typiquement utilis&amp;#233; pour une voie &amp;#224; quai. Le transit qui donne acc&amp;#232;s &amp;#224; la voie de stationnement en sens contraire est v&amp;#233;rifi&amp;#233;. Permet de manoeuvrer (e.g. pour coupler deux rames ou atteler une locomotive). 

Comme une VU, sauf que l&apos;on peut y manoeuvrer (pour coupler deux rames ou pour atteler une locomotive). Au lieu de v&amp;#233;rifier le transit de sens contraire de la VU, est v&amp;#233;rifi&amp;#233; le transit qui donne acc&amp;#232;s &amp;#224; la voie de stationnement en sens contraire.</rdfs:comment>
        <rdfs:label>StationTrackLocking</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#OpposingRouteLocking"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#betweenInterlockings"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#DirectionLocking"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#IpcsLocking"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#SingleTrackLocking"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#StandoffLocking"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#StationTrackLocking"/>
        </owl:disjointUnionOf>
        <rdfs:comment>Opposing route locking for line without points.
fr-FR: Enclenchement portant sur des portions de voie lin&amp;#233;aire, g&amp;#233;n&amp;#233;ralement sans aiguilles.</rdfs:comment>
        <rdfs:comment>betweenInterlockings
fr-FR: Enclenchement entre postes ou non.</rdfs:comment>
        <rdfs:label>TrackLocking</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TransitAndMovableElementPosition -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TransitAndMovableElementPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#checksTransit_TransitAndMovableElementPosition"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Transit_EAID_ACED038E_2CE8_4f0d_BB9E_FD9C5E14F957"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>TransitAndMovableElementPosition</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Transit_EAID_ACED038E_2CE8_4f0d_BB9E_FD9C5E14F957 -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Transit_EAID_ACED038E_2CE8_4f0d_BB9E_FD9C5E14F957">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#appliesToTvpSection_Transit"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TvpSection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#hasDirection_Transit"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A transit is a TVP section plus a direction.
fr-FR: Un transit correspond &amp;#224; une section TVP &amp;#224; laquelle on affecte un sens.</rdfs:comment>
        <rdfs:label>Transit</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#CrocodileSystemProperties -->


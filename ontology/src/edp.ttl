<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#ReleaseInstrument> a owl:Class ;
    rdfs:label "ReleaseInstrument" ;
    rdfs:comment "A device that releases control of an asset." ;

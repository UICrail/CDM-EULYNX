<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#IntegratedLevelCrossing> a owl:Class ;
    rdfs:label "IntegratedLevelCrossing" ;
    rdfs:comment "Level crossing system that is integrated in a technical system." ;

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#AspectProving> a owl:Class ;
    rdfs:label "AspectProving" ;
    rdfs:comment "If a signal fails to show a given aspect, then another signal is forced to show another, typically more restrictive, aspect." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#bestAllowedAspect> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#checksAspect> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#BackToBackLocking>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#LensDiffuser>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#ManualOverlapRelease>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStopMovement>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#OppositeTrackSignal>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroup> a owl:Class ;
    rdfs:label "PopGroup" ;
    rdfs:comment """Predicted Overrun Protection (POP) group of signals.
Overrun of any of the signals in the POP group triggers a closing of all signals in the group.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignment>,

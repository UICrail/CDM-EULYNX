            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Used to be the signal box short code. Today, the line code is used.</rdfs:comment>
        <rdfs:label>FullDesignation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#RailNodePath -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#RailNodePath">

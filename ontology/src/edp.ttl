<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdgeAccessPoint> a owl:Class ;
    rdfs:label "PlatformEdgeAccessPoint" ;
    rdfs:comment "The spot, projected on the platform edge, where passengers tend to cluster, typically near the stairs, escalator or elevator." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isLocatedAt_PlatformEdgeAccessPoint> ;

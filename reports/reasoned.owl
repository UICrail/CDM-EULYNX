        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficSign"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingSpeedProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment"/>
        <rdfs:comment>Relation between the signal, e.g. protection signal, or sign, and the level crossing activation or track crossing.
The signal/sign is specific to level crossing, e.g.
NR: whistle, fr: siffler</rdfs:comment>
        <rdfs:label>LevelCrossingSignalRelation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystem -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystem">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#VirtualTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#hasProperty_LevelCrossingSystem"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystemProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#protectsTrackCrossing"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossing"/>
        <rdfs:label>LevelCrossingSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystemProperty -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystemProperty">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#PathCrossingProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficLightProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#StAndrewsCross"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#ProtectionType"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TechnologyType"/>
        </owl:disjointUnionOf>
        <rdfs:label>LevelCrossingSystemProperty</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingTimerSet -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingTimerSet">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#appliesToIntegratedLevelCrossing_LevelCrossingTimerSet"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#IntegratedLevelCrossing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RadarReflector"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficSign"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingSpeedProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment"/>
        <rdfs:comment>Placeholder for specific national timers. 
E.g. minimum road open time: time during which a level crossing is guaranteed to be available to road traffic.</rdfs:comment>
        <rdfs:label>LevelCrossingTimerSet</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#Lidar -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#Lidar">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#ClearanceDetector"/>
        <rdfs:label>Lidar</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LocallyMonitoredLevelCrossing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LocallyMonitoredLevelCrossing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystem"/>
        <rdfs:comment>A level crossing system that is locally monitored by the train driver: The driver observes a signal that indicates the crossing working order. 
Failure and health status are optionally monitored and transmitted to an (unspecified) system (other than the IL logic).</rdfs:comment>
        <rdfs:comment>The difference is that the interlocking logic uses I/O from the self-supervised level crossing, but does not use I/O from the locally-monitored level crossing.</rdfs:comment>
        <rdfs:label>LocallyMonitoredLevelCrossing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#MainSignalProtectedLevelCrossing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#MainSignalProtectedLevelCrossing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#InterlockingIntegratedLevelCrossing"/>
        <rdfs:comment>A &lt;b&gt;LC &lt;/b&gt;system integrated with a route and protected by a signal, normally a main signal. 
The interlocking activates the LC and proves the closing before opening the signal.</rdfs:comment>
        <rdfs:label>MainSignalProtectedLevelCrossing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#PathCrossingProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#PathCrossingProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#hasPathOfType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#isLocatedToSide"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficLightProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#StAndrewsCross"/>
        <rdfs:label>PathCrossingProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#ProtectionType -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#ProtectionType">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystemProperty"/>
        <rdfs:comment>Type of protection. 
E.g.
&lt;ul&gt;
	&lt;li&gt;half-barrier&lt;/li&gt;
	&lt;li&gt;full-barrier&lt;/li&gt;
	&lt;li&gt;user-worked crossing with telephone&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>ProtectionType</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#Radar -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#Radar">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#ClearanceDetector"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#usesReflector"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RadarReflector"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Radar</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RadarReflector -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RadarReflector">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficSign"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingSpeedProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment"/>
        <rdfs:label>RadarReflector</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficLightProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficLightProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#StAndrewsCross"/>
        <rdfs:label>RoadTrafficLightProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficSign -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficSign">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#hasStAndrewsCross"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#StAndrewsCross"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingSpeedProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment"/>
        <rdfs:comment>Road traffic light or sign. Assembly drawings can be attached or referred to.
en-GB: Road Traffic Light (RTL)</rdfs:comment>
        <rdfs:label>RoadTrafficSign</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RouteIntegratedLevelCrossing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RouteIntegratedLevelCrossing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#InterlockingIntegratedLevelCrossing"/>
        <rdfs:comment>A &lt;b&gt;LC&lt;/b&gt; system that reports good working order. 
The interlocking will deny routes when this information is absent.</rdfs:comment>
        <rdfs:label>RouteIntegratedLevelCrossing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#SelfSupervisedLevelCrossing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#SelfSupervisedLevelCrossing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#IntegratedLevelCrossing"/>
        <rdfs:comment>A &lt;b&gt;LX&lt;/b&gt; system that has the logic to autonomously process triggers from route setting and/or train approach. The LX warns and/or closes the barriers when activated. The LX reports failures to the interlocking.</rdfs:comment>
        <rdfs:comment>The difference is that the interlocking logic uses I/O from the self-supervised level crossing, but does not use I/O from the locally-monitored level crossing.</rdfs:comment>
        <rdfs:label>SelfSupervisedLevelCrossing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#StAndrewsCross -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#StAndrewsCross">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:label>StAndrewsCross</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TechnologyType -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TechnologyType">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystemProperty"/>
        <rdfs:comment>The designation of the applied technology.
 E.g. the supplier designation: &quot;Siemens LC&quot;, &quot;EBUET 80&quot;.
&lt;ul&gt;
	&lt;li&gt;de-DE: e.g. Anrufschranke, BUES2000&lt;/li&gt;
	&lt;li&gt;it-IT: PL privati&lt;/li&gt;
	&lt;li&gt;nl-NL: AHOB&lt;/li&gt;
&lt;/ul&gt;
This value may be specialised in the national domain (see e.g. DB domain).</rdfs:comment>
        <rdfs:label>TechnologyType</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#VirtualTrackAsset"/>
        <rdfs:comment>B&amp;#220; Kreuzungspunkt</rdfs:comment>
        <rdfs:comment>Informs that vehicles or pedestrians cross railway tracks &lt;i&gt;at the same level&lt;/i&gt;.
This class allows naming the street, road or path according to national rules (e.g. NR informs streetname nor type).
The track crossing can, &lt;i&gt;but need not&lt;/i&gt;, be protected by a level crossing system.</rdfs:comment>
        <rdfs:label>TrackCrossing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#appliesToTrackCrossing_TrackCrossingProperties"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#hasAdditionalPath"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#PathCrossingProperties"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingSpeedProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment"/>
        <rdfs:label>TrackCrossingProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingSpeedProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingSpeedProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment"/>
        <rdfs:comment>The set of speeds that determined the configuration of the activation triggering.
These speeds govern the design of the level crossing but are often not stored in the data.
The calculation documents can be stored in an attachment.</rdfs:comment>
        <rdfs:label>TrackCrossingSpeedProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#average"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#peak"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Traffic volume for which the crossing is designed.
The number results from a nationally regulated formula that can include both rail and road traffic.
The calculation documents can be stored in an attachment.</rdfs:comment>
        <rdfs:label>TrafficMoment</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationDevice -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationDevice">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#composedOfUiElement"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#isOfLocalOperationDeviceType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#isSupportedBy_LocalOperationDevice"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentSupport"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiElement"/>
        <rdfs:comment>The terminal for locally working line-side elements.</rdfs:comment>
        <rdfs:label>LocalOperationDevice</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiButton -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiButton">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiElement"/>
        <rdfs:label>LocalOperationUiButton</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiElement -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:comment>A user interface component such as a button, knob, switch, lever, indicator, lamp, buzzer or pull cord that is mounted in a local operation device and that fulfills a given function.
The UI element interacts with (the state of) a signal or movable element (to request a movement).</rdfs:comment>
        <rdfs:label>LocalOperationUiElement</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiIndicator -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiIndicator">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiElement"/>
        <rdfs:label>LocalOperationUiIndicator</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiLever -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiLever">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiElement"/>
        <rdfs:label>LocalOperationUiLever</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiSwitch -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiSwitch">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Local_operation_devices#LocalOperationUiElement"/>
        <rdfs:label>LocalOperationUiSwitch</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#DispatchPosition -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#DispatchPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isLocatedAt_DispatchPosition"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformAccess"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#StoppingPoint"/>
        <rdfs:comment>The spot from where trains can be dispatched, i.e. the spot where the dispatcher can sight train(s) and signals. Extra equipment like plungers can be installed here.</rdfs:comment>
        <rdfs:label>DispatchPosition</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#InfrastructuralPlatformEdge -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#InfrastructuralPlatformEdge">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge"/>
        <rdfs:comment>All of the platform edge adjacent to a track. Includes ramps, stairs, fenced off or restricted areas where trains don&apos;t normally stop.</rdfs:comment>
        <rdfs:label>InfrastructuralPlatformEdge</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#OperationalPlatformEdge -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#OperationalPlatformEdge">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge"/>
        <rdfs:comment>Where passenger can access trains.
The definition is national. It depends on signal sighting, length of train, position of doors, height of steps, presence of barriers or signs.
It is possible to define an edge &lt;i&gt;per direction&lt;/i&gt;, which can be relevant to coupling, splitting or turn-operations (NR and ProRail).</rdfs:comment>
        <rdfs:label>OperationalPlatformEdge</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformAccess -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformAccess">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isOfPlatformAccessType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#leadsPassengersToPlatformEdgeAccessPoint"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdgeAccessPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#StoppingPoint"/>
        <rdfs:comment>Means of platform access. Relevant for positioning operational stops.</rdfs:comment>
        <rdfs:label>PlatformAccess</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#hasDispatchPosition"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#DispatchPosition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#hasProperty_PlatformEdge"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdgeProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isLocatedAt_PlatformEdge"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformFacility"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformRoof"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#InfrastructuralPlatformEdge"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#OperationalPlatformEdge"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#UsablePlatformEdge"/>
        </owl:disjointUnionOf>
        <rdfs:comment>Part of the platform facility adjacent to a track.
The designation of the platform edge is for passenger information systems, typically a number plus a letter e.g. &lt;i&gt;platform 6&lt;/i&gt; or &lt;i&gt;platform 10a/b&lt;/i&gt;.</rdfs:comment>
        <rdfs:label>PlatformEdge</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdgeAccessPoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdgeAccessPoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isLocatedAt_PlatformEdgeAccessPoint"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isOnPlatformEdge"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdgeProperty"/>
        <rdfs:comment>The spot, projected on the platform edge, where passengers tend to cluster, typically near the stairs, escalator or elevator.</rdfs:comment>
        <rdfs:label>PlatformEdgeAccessPoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdgeProperty -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdgeProperty">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:label>PlatformEdgeProperty</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformFacility -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformFacility">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#hasPlatformAccess"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformAccess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformRoof"/>
        <rdfs:comment>Allows passengers to board and alight from trains. Has one or more edges and passenger accesses.  
The platform designation is usually composed of the names of the platform edges,&lt;i&gt; &lt;/i&gt;e.g. &lt;i&gt;Platform 3 and 4&lt;/i&gt;. Sometimes, a name like &lt;i&gt;Platform A with tracks 102 and 103&lt;/i&gt; may occur.</rdfs:comment>
        <rdfs:label>PlatformFacility</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformRoof -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformRoof">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#appliesToPlatformEdge_PlatformRoof"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isLocatedAt_PlatformRoof"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Platform roof, insofar relevant to signalling concerns such as signal fixation, obscuration and train stopping location.</rdfs:comment>
        <rdfs:label>PlatformRoof</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#StoppingPoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#StoppingPoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isLocatedAt_StoppingPoint"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The operational train stopping point.</rdfs:comment>
        <rdfs:label>StoppingPoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#UsablePlatformEdge -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#UsablePlatformEdge">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge"/>
        <rdfs:comment>Where trains are allowed to stand.
Notes:
&lt;ul&gt;
	&lt;li&gt;NR and SNCF: ends at signal minus sighting distance.&lt;/li&gt;
&lt;/ul&gt;
&lt;ul&gt;
	&lt;li&gt;NR: platform standage.&lt;/li&gt;
&lt;/ul&gt;
&lt;ul&gt;
	&lt;li&gt;ProRail: bruikbare lengte.&lt;/li&gt;
	&lt;li&gt;RFI only use operational platform edge.&lt;/li&gt;
	&lt;li&gt;DB design rules consider the &lt;i&gt;usable &lt;/i&gt;length only.&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>UsablePlatformEdge</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Crossing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Crossing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointCrossing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#hasDiamond"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Diamond"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#refersToRsmCrossing"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Installation where tracks intersect.
Some crossings, especially high speed ones, have a switched diamond to close the gap at the crossing (de-DE: Flachkreuzung mit beweglichen Herzst&amp;#252;ckspitzen, nl-NL: kruising met beweegbaar puntstuk). 
The slip points to which the crossing connects, if any, are separate instances of the Point class.</rdfs:comment>
        <rdfs:label>Crossing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Derailer -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Derailer">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem"/>
        <rdfs:comment>Glossary definition: &quot;A safety device attached to a rail, that will, when operated, cause a derailment of a train making an unauthorised movement.&quot;
Not to be confused with trap points.
The derailment direction (direction in which the train is ejected from the rails) is an attribute of the individual derailer component(s).</rdfs:comment>
        <rdfs:label>Derailer</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#DerailerComponent -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#DerailerComponent">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#LocatedMovableComponent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#derailsInDirection"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#hasGuardRail"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>DerailerComponent</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#DerailerElementConfiguration -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#DerailerElementConfiguration">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElementConfiguration"/>
        <rdfs:label>DerailerElementConfiguration</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Diamond -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Diamond">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#isLocatedAt_Diamond"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointHeating"/>
        <rdfs:comment>The lozenge shape where the rails intersect in a crossing.</rdfs:comment>
        <rdfs:label>Diamond</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#DiamondHalf -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#DiamondHalf">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Diamond"/>
        <rdfs:label>DiamondHalf</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#ElectricDrive -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#ElectricDrive">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointDrive"/>
        <rdfs:comment>Electric point drive.</rdfs:comment>
        <rdfs:label>ElectricDrive</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#ExternalDetector -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#ExternalDetector">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointMachine"/>
        <rdfs:label>ExternalDetector</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#FacingPointLock -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#FacingPointLock">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#LocatedMovableComponent"/>
        <rdfs:comment>A movable lock that keeps the point blade(s) in place.
en-GB: Facing Point Lock (FPL). The scheme design provides the label for the designation. The label maps to the inherited designation class.</rdfs:comment>
        <rdfs:label>FacingPointLock</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#FoulTrackControl -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#FoulTrackControl">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#appliesToPointElementInPosition_FoulTrackControl"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#PointElementAndPosition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Normalisation"/>
        <rdfs:comment>The train detector within a fouling track dictates which movable element positions must be checked and which section must be clear as a consequence (if any).
Typically used in Germany.</rdfs:comment>
        <rdfs:label>FoulTrackControl</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Frog -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Frog">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#LocatedMovableComponent"/>
        <rdfs:comment>The part of a turnout, a crossing, or a gantlet, where the rails have an intersection which allows the wheel flanges to cross the running rail. The frog may be fixed or moveable.
Also known as movable nose or swing nose.</rdfs:comment>
        <rdfs:label>Frog</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#HandOperated -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#HandOperated">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Mechanism"/>
        <rdfs:label>HandOperated</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#HydraulicDrive -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#HydraulicDrive">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointDrive"/>
        <rdfs:comment>Point drive uses hydraulic pressure to throw the point. 
Note that a point machine equipped with an electric pump that builds up hydraulic pressure is considered an electric drive.</rdfs:comment>
        <rdfs:label>HydraulicDrive</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#LocatedMovableComponent -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#LocatedMovableComponent">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponent"/>
        <rdfs:comment>A movable component that is spot-located but not specified in the signalling domain, e.g. movable bridges, water barriers. 
The subtypes of this class represent movable components that are specified in the signalling domain.</rdfs:comment>
        <rdfs:label>LocatedMovableComponent</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Mechanical -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Mechanical">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Mechanism"/>
        <rdfs:label>Mechanical</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Mechanism -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Mechanism">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponent"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#HandOperated"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Mechanical"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointMachine"/>
        </owl:disjointUnionOf>
        <rdfs:comment>A mechanism designed to drive and/or detect movable components.</rdfs:comment>
        <rdfs:label>Mechanism</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableBridge -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableBridge">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem"/>
        <rdfs:comment>A railway bridge that can be opened or closed to train traffic.</rdfs:comment>
        <rdfs:label>MovableBridge</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableBufferStop -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableBufferStop">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem"/>
        <rdfs:comment>A buffer stop that can be remotely controlled.</rdfs:comment>
        <rdfs:label>MovableBufferStop</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableCatenary -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableCatenary">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem"/>
        <rdfs:comment>An interlocking can throw an overhead catenary just like a point or a crossing with movable frog. A movable overhead catenary is always situated over a point or a crossing.</rdfs:comment>
        <rdfs:label>MovableCatenary</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponent -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponent">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#LocatedMovableComponent"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointBlades"/>
        </owl:disjointUnionOf>
        <rdfs:comment>The smallest mobile part of a movable element.</rdfs:comment>
        <rdfs:label>MovableComponent</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponentConfiguration -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponentConfiguration">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAssetConfiguration"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#appliesToMovableComponent"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A set of properties that applies to a movable component.
The number of point machines, as intended by EULYNX specification Eu.P.4957, is the sum of the number of point drives and external detectors.</rdfs:comment>
        <rdfs:comment>numberOfExternalDetectors
The number of external blade position detectors.
This excludes detectors inside the drive mechanism. Not informed when attribute hasExternalDetectors is false.</rdfs:comment>
        <rdfs:comment>numberOfPointDrives
The number of drives, that both drive and detect this movable component.</rdfs:comment>
        <rdfs:label>MovableComponentConfiguration</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#isComposedOfMovableComponent"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem"/>
        <rdfs:comment>The movable element is an abstraction that associates the underlying movable components with the mechanism(s) that move them. The signaller selects and operates one movable element and needn&apos;t be concerned with the underlying individual components of the movable element.</rdfs:comment>
        <rdfs:comment>canReportDegradedStatus
True: this movable element can report a degraded status which means a loss of full detection. This is a function of the reports from the individual detectors, some of which may be crucial or not.</rdfs:comment>
        <rdfs:label>MovableElement</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElementConfiguration -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElementConfiguration">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAssetConfiguration"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#appliesToMovableElement_MovableElementConfiguration"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#isInControlMode"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#hasFourWireInterface"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#DerailerElementConfiguration"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointCrossingElementConfiguration"/>
        </owl:disjointUnionOf>
        <rdfs:label>MovableElementConfiguration</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#isComposedOfMovableElement"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Abstract class for systems that have movable elements. Movable systems either divert, halt or derail railway traffic.</rdfs:comment>
        <rdfs:label>MovableSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Normalisation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Normalisation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#appliesToMovableElement_Normalisation"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#isOfNormalisationType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The movable element returns to the preferred position when it is no longer claimed by a route, typically because the passing train has cleared the movable element.</rdfs:comment>
        <rdfs:label>Normalisation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PneumaticDrive -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PneumaticDrive">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointDrive"/>
        <rdfs:label>PneumaticDrive</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Point -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Point">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointCrossing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#isOfPointType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>en-GB: point
en-US: switch
fr-FR: aiguillage
nl-NL: wissel
de-DE: Weiche</rdfs:comment>
        <rdfs:label>Point</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointBlade -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointBlade">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointBlades"/>
        <rdfs:comment>Individual switch rail (NetworkRail can separately control the blades in some cases).</rdfs:comment>
        <rdfs:label>PointBlade</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointBlades -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointBlades">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#refersToRsmTurnout"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The pair of switch rails of a point that are secured together by a stretcher bar.
The location is given by the origin of the associated RSM Turnout.</rdfs:comment>
        <rdfs:label>PointBlades</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointCrossing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointCrossing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#hasSwitchedNose"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Generic term for point or crossing installation. Typically a complete replaceable track assembly.</rdfs:comment>
        <rdfs:label>PointCrossing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointCrossingElementConfiguration -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointCrossingElementConfiguration">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElementConfiguration"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#canReportTrailed"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>PointCrossingElementConfiguration</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointDrive -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointDrive">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointMachine"/>
        <rdfs:label>PointDrive</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointHeating -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointHeating">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#heatSource"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>heatSource
Typically gas, electric or geothermal.</rdfs:comment>
        <rdfs:label>PointHeating</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointMachine -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointMachine">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Mechanism"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#ExternalDetector"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointDrive"/>
        </owl:disjointUnionOf>
        <rdfs:label>PointMachine</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#RailwayBarrier -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#RailwayBarrier">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableSystem"/>
        <rdfs:comment>Movable barrier that can be opened or closed to &lt;i&gt;railway &lt;/i&gt;traffic. 
For instance a water barrier in a tunnel or dike. 

For barriers that block &lt;i&gt;road traffic&lt;/i&gt;, refer to Level Crossings. 
Gated level crossings have a dual function, blocking either road or rail traffic. These are detected much like level crossing and therefore considered Level Crossings in our model.</rdfs:comment>
        <rdfs:label>RailwayBarrier</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PhysicalPowerSupplyModule -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PhysicalPowerSupplyModule">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PowerSupplyModule"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#isHousedIn_PhysicalPowerSupplyModule"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A physical power supply field module.</rdfs:comment>
        <rdfs:label>PhysicalPowerSupplyModule</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PowerOutputChannelProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PowerOutputChannelProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#providesNominalVoltage"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#nominalPower"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PowerSourceRelation"/>
        <rdfs:comment>The parameters of a power output channel.</rdfs:comment>
        <rdfs:label>PowerOutputChannelProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PowerSourceRelation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PowerSourceRelation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#isPrimarySource"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#isUps"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Describes the sourcing of power to a power supply.</rdfs:comment>
        <rdfs:label>PowerSourceRelation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PowerSupplyModule -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PowerSupplyModule">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PhysicalPowerSupplyModule"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#VirtualPowerSupplyModule"/>
        </owl:disjointUnionOf>
        <rdfs:comment>Installation that supplies electric power to signalling subsystems and devices.</rdfs:comment>
        <rdfs:label>PowerSupplyModule</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#VirtualPowerSupplyModule -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#VirtualPowerSupplyModule">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#PowerSupplyModule"/>
        <rdfs:comment>Fa&amp;#231;ade for a power supplied by an object such as controller or level crossing.</rdfs:comment>
        <rdfs:label>VirtualPowerSupplyModule</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ConductorRail -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ConductorRail">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#isLocatedAt_ConductorRail"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#isPlacedAt"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A physical section of conductor rail that is placed to the left, right or centre.</rdfs:comment>
        <rdfs:label>ConductorRail</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ConductorRailGap -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ConductorRailGap">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationGap"/>
        <rdfs:comment>A gap in the conductor rail traction.</rdfs:comment>
        <rdfs:label>ConductorRailGap</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ConductorRailSection -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ConductorRailSection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#isOfConductorVoltageType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A section of the track equipped with conductor rail, often referred to as third rail.</rdfs:comment>
        <rdfs:label>ConductorRailSection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationGap -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationGap">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSegment"/>
        <rdfs:comment>Gap in the traction system where no traction power can ever be drawn.
en-UK: neutral section in overhead line systems, gap in third rail systems.</rdfs:comment>
        <rdfs:label>ElectrificationGap</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationOverlap -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationOverlap">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSegment"/>
        <rdfs:comment>Section where overhead lines overlap. When a train stops in the overlap, chances are that current runs through and damages the pantograph. Trains should therefore not stop here. 
fr-FR: sectionnement critique
nl-NL: open spaninrichting.</rdfs:comment>
        <rdfs:comment>type
Description of the type of overlap: booster, auto, traction mounted auxiliary, normally open/closed switch.
Used for assessing where to place signals to minimise the risk of trains stopping in the overlap.</rdfs:comment>
        <rdfs:label>ElectrificationOverlap</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSection -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSegment"/>
        <rdfs:comment>Elementary section allowing electric train traction to be switched on or off.</rdfs:comment>
        <rdfs:label>ElectrificationSection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSegment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSegment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationGap"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationOverlap"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSection"/>
        </owl:disjointUnionOf>
        <rdfs:comment>Electrification segment with information relevant to signalling.</rdfs:comment>
        <rdfs:label>ElectrificationSegment</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#OverheadLineGap -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#OverheadLineGap">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationGap"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#wired"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A gap in the overhead traction. 
A bascule bridge would typically have a gap with open wire and no type.</rdfs:comment>
        <rdfs:comment>wired
Indicates whether a (neutral) line is present.
&lt;ul&gt;
	&lt;li&gt;true: the pantograph must be lowered.&lt;/li&gt;
	&lt;li&gt;false: no need to lower the pantograph.&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>OverheadLineGap</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#OverheadLineSection -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#OverheadLineSection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationSection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#isOfTractionVoltageType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A section of the track where traction power is provided by an overhead line.</rdfs:comment>
        <rdfs:label>OverheadLineSection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#ActiveSignal -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#ActiveSignal">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#PhysicalSignal"/>
        <rdfs:comment>A signal with an actively controlled aspect.</rdfs:comment>
        <rdfs:label>ActiveSignal</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#FictitiousSignal -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#FictitiousSignal">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#NonPhysicalSignal"/>
        <rdfs:comment>A software object in the interlocking. It may be visible on the signaller control display but not on the driver&apos;s DMI. Trains don&apos;t stop at a fictitious signal.
Also called cross-boundary signal (see &lt;a href=&quot;$diagram://{91C01CCE-B70B-480e-9A87-4B436D3B4FD8}&quot;&gt;&lt;font color=&quot;#0000ff&quot;&gt;&lt;u&gt;here&lt;/u&gt;&lt;/font&gt;&lt;/a&gt;).</rdfs:comment>
        <rdfs:label>FictitiousSignal</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#LightSignal -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#LightSignal">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#ActiveSignal"/>
        <rdfs:comment>isIntentionallyDarkAllowed
The line-side system can switch the light signal to intentionally dark when a cab signalling ATP system such as LZB or ETCS is leading. 
The signal lamps are intentionally turned off and the driver disregards the light signal.
This avoids conflict between line-side aspect and cab aspect in dual signalling environments.

Not to be used when a signal is switched to a special aspect (white lamp or white cross), indicating that the signal should be disregarded. The other signal lamps are dark but this is not meant by intentionally dark.

Notes on dark signals:
&lt;ul&gt;
	&lt;li&gt;A light signal that is dark because it has failed represents danger.&lt;/li&gt;
	&lt;li&gt;In the UK, dark mode applies to LX warning light that switch to dark on purpose, e.g. a failed level crossing in the UK because a permanent warning light invites undesirable behaviour by motorists.&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:comment>isTunnelSignal
Signal placed in tunnels, typically used to indicate special fixing requirements and/or light intensity.</rdfs:comment>
        <rdfs:label>LightSignal</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#MechanicalSignal -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#MechanicalSignal">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#ActiveSignal"/>
        <rdfs:label>MechanicalSignal</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Milepost -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Milepost">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Sign"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#type_Milepost"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#valueShown"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Milepost</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#NonPhysicalSignal -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#NonPhysicalSignal">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal"/>
        <rdfs:comment>A signal without a physical line-side appearance. 
The non-physical signal need not send information to the train driver as opposed to a physical signal.</rdfs:comment>
        <rdfs:label>NonPhysicalSignal</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#PhysicalSignal -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#PhysicalSignal">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal"/>
        <rdfs:comment>A signal with a physical line-side appearance.</rdfs:comment>
        <rdfs:label>PhysicalSignal</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#ProceedMessage -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#ProceedMessage">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#AspectSet"/>
        <rdfs:comment>Indicates that the train may proceed.

Note: the end user can specialise this class to adapt it to national needs.</rdfs:comment>
        <rdfs:label>ProceedMessage</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Sign -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Sign">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#PhysicalSignal"/>
        <rdfs:comment>A signal with a passive aspect, &lt;i&gt;&lt;u&gt;not controlled &lt;/u&gt;&lt;/i&gt;by the signalling system. 
A sign (or board) sends a permanent message to the driver. Its message and physical appearance (shape, colour, patterns) are normalised.

Note: A sign can carry a lamp showing one single aspect, and the interlocking can &lt;i&gt;&lt;u&gt;only read &lt;/u&gt;&lt;/i&gt;the status of the lamp (e.g. a sign with a lamp marking the end of the track).</rdfs:comment>
        <rdfs:label>Sign</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#hasProperty_Signal"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Signal</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#SignalFrame -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#SignalFrame">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#hasPosition"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#OffsetOfReferencePoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#isOfSignalFrameType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#isFixed"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#SignalFrameComponent"/>
        <rdfs:comment>Generic term for the information-carriers: sign, board, nameplates, lamp-frames, notice boards. 
It is most often part of a signal.</rdfs:comment>
        <rdfs:label>SignalFrame</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#SignalFrameComponent -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#SignalFrameComponent">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:label>SignalFrameComponent</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#StopMessage -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#StopMessage">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#AspectSet"/>
        <rdfs:comment>Indicates that the train must stop.</rdfs:comment>
        <rdfs:comment>imperative
This boolean modifies of the message.
&lt;ul&gt;
	&lt;li&gt;True: the signalling system ascertains danger beyond the signal: the stop must be respected.&lt;/li&gt;
&lt;/ul&gt;
&lt;ul&gt;
	&lt;li&gt;False: a failure prevents the signalling system from asserting danger beyond the signal. Typically, the driver may then proceed with caution and permission given by the signaller.&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>StopMessage</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#VirtualSignal -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#VirtualSignal">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#NonPhysicalSignal"/>
        <rdfs:comment>Limits a virtual block in systems such as Hybrid Level 3 or LZB. A train may be stopped at a virtual signal. The signal may be visible only on the signaller&apos;s control display and driver&apos;s DMI.</rdfs:comment>
        <rdfs:label>VirtualSignal</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#ActiveAspect -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#ActiveAspect">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#Aspect"/>
        <rdfs:comment>Atomic dynamic information displayed by the signal.</rdfs:comment>
        <rdfs:label>ActiveAspect</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#ActiveAspectSet -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#ActiveAspectSet">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessage"/>
        <rdfs:comment>A set of actively controlled signal aspects.</rdfs:comment>
        <rdfs:label>ActiveAspectSet</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#AlternateFlash -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#AlternateFlash">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SynchedFlashing"/>
        <rdfs:comment>Aspects flash alternately, i.e. in counter-phase.
Note: RFI uses flashing in phase or counter-phase to distinguish signal messages.</rdfs:comment>
        <rdfs:label>AlternateFlash</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#Aspect -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#Aspect">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#aspectId"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalAspectDegradation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessage"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessageRelation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalVector"/>
        <rdfs:comment>Atomic information displayed by the signal, conveyed by means of light, shape, text, symbol, form, colour.
de-DE: Signalbegriff</rdfs:comment>
        <rdfs:label>Aspect</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#AspectSet -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#AspectSet">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessage"/>
        <rdfs:comment>A set of active and/or passive aspects representing a message sent by a signal. 
Typically, the meaning of the message is defined in a rule book.</rdfs:comment>
        <rdfs:label>AspectSet</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#FlashInPhase -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#FlashInPhase">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SynchedFlashing"/>
        <rdfs:comment>Aspects flash in phase.
Note: RFI uses flashing in phase or counter-phase to distinguish signal messages.</rdfs:comment>
        <rdfs:label>FlashInPhase</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#PassiveAspect -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#PassiveAspect">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#Aspect"/>
        <rdfs:label>PassiveAspect</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalAspectDegradation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalAspectDegradation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#appliesToActiveAspectSet"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#ActiveAspectSet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#isMostRestrictive"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessage"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessageRelation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalVector"/>
        <rdfs:comment>Provides signal aspect degradation information that is associated with a given light signal.</rdfs:comment>
        <rdfs:comment>isMostRestrictive
True: the active aspect set is the most restrictive that the signal shows:
&lt;ul&gt;
	&lt;li&gt;when not controlled by the interlocking, e.g. in case of failed communication between interlocking and signal controller.&lt;/li&gt;
	&lt;li&gt;during system start.&lt;/li&gt;
&lt;/ul&gt;
False: degrade to the given set of active aspects.</rdfs:comment>
        <rdfs:label>SignalAspectDegradation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessage -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessage">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#semantic"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessageRelation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalVector"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#ActiveAspectSet"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#AspectSet"/>
        </owl:disjointUnionOf>
        <rdfs:label>SignalMessage</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessageRelation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessageRelation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#hasDependentMessage"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#hasMasterMessage"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalVector"/>
        <rdfs:comment>A signal-message relation is composed of two pairs master(signal,message) and dependent(signal,message).
The message of the master signal dictates the message of the dependent signal.</rdfs:comment>
        <rdfs:label>SignalMessageRelation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalVector -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalVector">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#commandsActiveAspectSet"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#ActiveAspectSet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#basicAspectType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#directionIndicator"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#directionIndicatorAnnouncements"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#extensionBasicAspectType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#speedIndicator"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#speedIndicatorAnnouncement"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The EULYNX signal vector is defined by the SCI-LS cluster and conveys active aspect controls from the interlocking to the signal controller. It consists of 6 bytes of information (Eu.DK.254) mapped to integers.</rdfs:comment>
        <rdfs:label>SignalVector</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#Symbol -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#Symbol">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#value_Symbol"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SynchedFlashing"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#TextInformation"/>
        <rdfs:label>Symbol</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SynchedFlashing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SynchedFlashing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#TextInformation"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#AlternateFlash"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#FlashInPhase"/>
        </owl:disjointUnionOf>
        <rdfs:comment>Two light aspects that flash in synch. 
The frequency and phase difference of flashing are given by national rules.</rdfs:comment>
        <rdfs:label>SynchedFlashing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#TextInformation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#TextInformation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#value_TextInformation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Maps to SDEF legend, e.g. the message on a notice board.</rdfs:comment>
        <rdfs:label>TextInformation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#AspectProving -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#AspectProving">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#bestAllowedAspect"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#checksAspect"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#BackToBackLocking"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#LensDiffuser"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#ManualOverlapRelease"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStopMovement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#OppositeTrackSignal"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroupAssociation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
        <rdfs:comment>If a signal fails to show a given aspect, then another signal is forced to show another, typically more restrictive, aspect.</rdfs:comment>
        <rdfs:label>AspectProving</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#BackToBackLocking -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#BackToBackLocking">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#isOfCategory"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#LensDiffuser"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#ManualOverlapRelease"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStopMovement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#OppositeTrackSignal"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroupAssociation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
        <rdfs:comment>Applies to two signals and, if applicable, all designated tracks in between these signals.
When one of the two signals is opened, the other remains closed.</rdfs:comment>
        <rdfs:label>BackToBackLocking</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#DispatchAnnouncerAssignment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#DispatchAnnouncerAssignment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroup"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignment"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalPlan"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalSightingDistance"/>
        <rdfs:comment>The entry signal is associated either with
&lt;ul&gt;
	&lt;li&gt;a light signal informing train staff to prepare for imminent departure (de-DE: Fahrtank&amp;#252;nder - wei&amp;#223;es Dreieck)&lt;/li&gt;
	&lt;li&gt;a counter indicating the remaining time to planned departure (ProRail)&lt;/li&gt;
&lt;/ul&gt;
&lt;ul&gt;
	&lt;li&gt;a system that messages the train staff mobile device (de-DE: dann entf&amp;#228;llt der physische Fahrtank&amp;#252;nder).&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>DispatchAnnouncerAssignment</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#LensDiffuser -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#LensDiffuser">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#appliesToLightSignal_LensDiffuser"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#LightSignal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#ManualOverlapRelease"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStopMovement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#OppositeTrackSignal"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroupAssociation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
        <rdfs:comment>Indicates whether the signal is equipped with a lens diffuser. 
It can be specialised and associated with a set of diffuser types.</rdfs:comment>
        <rdfs:label>LensDiffuser</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#ManualOverlapRelease -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#ManualOverlapRelease">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#appliesToSignal_ManualOverlapRelease"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStopMovement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#OppositeTrackSignal"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroupAssociation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
        <rdfs:comment>Indicates whether the signal allows manual release of the overlap.</rdfs:comment>
        <rdfs:label>ManualOverlapRelease</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStandardPosition -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStandardPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#value_NonStandardPosition"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalFunction"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalType"/>
        <rdfs:comment>Signals are normally placed at regulated standard positions. In exceptional circumstances, the signal is placed differently which may require additional documentation, eg. a 3D BIM model, and dispensation.
This common EULYNX DP class can therefore be tailored to national needs. For instance:
&lt;ul&gt;
	&lt;li&gt;Germany: two double-track arrangements would lead to confusing situations so the signals can be placed at the other side of the track. A checkered sign points out this fact to the driver.&lt;/li&gt;
&lt;/ul&gt;
&lt;ul&gt;
	&lt;li&gt;France: signals in Alsace - Lorraine region are placed on the other side as in other French regions.&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>NonStandardPosition</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStopMovement -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStopMovement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#appliesToSignal_NonStopMovement"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#hasCondition_NonStopMovement"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#OppositeTrackSignal"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroupAssociation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
        <rdfs:comment>Indicates whether the train may proceed beyond the signal with or without stopping.</rdfs:comment>
        <rdfs:label>NonStopMovement</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#OppositeTrackSignal -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#OppositeTrackSignal">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#appliesToSignal_OppositeTrackSignal"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroupAssociation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
        <rdfs:comment>Applies to a signal whose direction is opposite to the normal direction of traffic, that is a signal applying to trains travelling on the opposite track.

Applies to double track lines only.
Not to be confused with the topological direction of the linear element, which is not related to the direction of traffic.</rdfs:comment>
        <rdfs:label>OppositeTrackSignal</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroup -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroup">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignment"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalPlan"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalSightingDistance"/>
        <rdfs:comment>Predicted Overrun Protection (POP) group of signals.
Overrun of any of the signals in the POP group triggers a closing of all signals in the group.</rdfs:comment>
        <rdfs:label>PopGroup</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroupAssociation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroupAssociation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#appliesToPopGroup"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroup"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#appliesToSignal_PopGroupAssociation"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
        <rdfs:comment>Class that allocates a signal to a POP group. Membership can be conditional.

The sensor that detects an overrun is given by rule; typically the first TDS section beyond the signal.</rdfs:comment>
        <rdfs:comment>condition
Optional note describing a condition.
Could state that overrun of the signal doesn&apos;t replace other signals in the group.</rdfs:comment>
        <rdfs:label>PopGroupAssociation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalPlan"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalSightingDistance"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignmentPointDescription"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignmentPointOnTrack"/>
        </owl:disjointUnionOf>
        <rdfs:label>SignalAlignment</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignmentPointDescription -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignmentPointDescription">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#description_SignalAlignmentPointDescription"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Description of the alignment point, i.e. the spot that is targeted when orienting the signal head. 
Can be used in exceptional cases such as tight curves to describe a target that is situated off- track, for instance &quot;line-side radio mast&quot;.

NR normally targets the signal&apos;s  AWS magnet and alternatively a given distance from the signal, or a spot on the track at a given distance from the signal.</rdfs:comment>
        <rdfs:label>SignalAlignmentPointDescription</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignmentPointOnTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignmentPointOnTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalAlignment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#distance"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The signal must be aligned such that the driver can see it. This class describes the position (upstream on the track) of the target of the signal: distance, and optionally height.
This information is typically checked during the installation and testing phases.</rdfs:comment>
        <rdfs:label>SignalAlignmentPointOnTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalFunction -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalFunction">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalType"/>
        <rdfs:comment>Operational function of the signal, e.g. entry or exit signal, block signal, bridge warning signal. These functions are nationally defined and can be described in the national domains (outside the common EULYNX DP scope).</rdfs:comment>
        <rdfs:label>SignalFunction</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalPlan -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalPlan">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#aspectRelation"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessageRelation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalSightingDistance"/>
        <rdfs:label>SignalPlan</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalPostTelephone -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalPostTelephone">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#Telephone"/>
        <rdfs:comment>Telephone for communication between train driver and signaller.</rdfs:comment>
        <rdfs:label>SignalPostTelephone</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:label>SignalProperty</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalSightingDistance -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalSightingDistance">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#appliesToSignal_SignalSightingDistance"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#PhysicalSignal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Reading distance defined following national rules.</rdfs:comment>
        <rdfs:label>SignalSightingDistance</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalType -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalType">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty"/>
        <rdfs:comment>General class for describing the signal type. National types can be described in the national domains. 
For instance: signal head type as defined by NR.</rdfs:comment>
        <rdfs:label>SignalType</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#HorizontalOffsetOfReferencePoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#HorizontalOffsetOfReferencePoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#OffsetOfReferencePoint"/>
        <rdfs:label>HorizontalOffsetOfReferencePoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#OffsetOfReferencePoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#OffsetOfReferencePoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#isLocatedAt_OffsetOfReferencePoint"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#value_OffsetOfReferencePoint"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A signal frame has a reference point that is nationally defined:
&lt;ul&gt;
	&lt;li&gt;a lamp, typically the red lamp, or&lt;/li&gt;
	&lt;li&gt;the centre of a set of lamps, or&lt;/li&gt;
	&lt;li&gt;the edge of a frame nearest to train gauge.&lt;/li&gt;
&lt;/ul&gt;
This reference point has:
&lt;ul&gt;
	&lt;li&gt;a spot location.&lt;/li&gt;
	&lt;li&gt;an horizontal offset, e.g. 1,8 metres from the nearest rail.&lt;/li&gt;
	&lt;li&gt;a vertical offset, e.g. 3,6 metres above the top of the highest rail.&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>OffsetOfReferencePoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#SignalLocation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#SignalLocation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#description_SignalLocation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Description of the area where the signal is located, to help maintenance workers to find the signal in the field.
Can be an informal description (e.g. near junction x) or depend on national regulations (e.g. DE Bezeichnung nach Ril 100).</rdfs:comment>
        <rdfs:label>SignalLocation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#VerticalOffsetOfReferencePoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#VerticalOffsetOfReferencePoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Location#OffsetOfReferencePoint"/>
        <rdfs:label>VerticalOffsetOfReferencePoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#proving"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#CompoundLogicalObjectAndState"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#LevelCrossingAndState"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#LockoutAreaAndState"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#LozAndState"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableElementAndPosition"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#OtherAssetAndState"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SectionAndVacancy"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#TpsAndState"/>
        </owl:disjointUnionOf>
        <rdfs:comment>A generic pair of (asset, state). 
This base class is abstract and must be specialised. The specialisations refer to a track asset (signal, section, point, etc.) plus the given status of that asset.</rdfs:comment>
        <rdfs:label>AssetAndState</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#CompoundLogicalObjectAndState -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#CompoundLogicalObjectAndState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#refersToCompoundLogicalObject"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#CompoundLogicalObject"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#HighOrLow"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A pair (Compound Logical Object, boolean).</rdfs:comment>
        <rdfs:comment>HighOrLow
High equates to 1=true means safe for train passage.
Low equates to 0=false means unsafe for train passage.</rdfs:comment>
        <rdfs:label>CompoundLogicalObjectAndState</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#Condition -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#Condition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SystemState"/>
        <rdfs:label>Condition</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#CrossingElementAndPosition -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#CrossingElementAndPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableElementAndPosition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inPosition_CrossingElementAndPosition"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>CrossingElementAndPosition</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#DerailerElementAndPosition -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#DerailerElementAndPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableElementAndPosition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inPosition_DerailerElementAndPosition"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A pair (derailer element, position).

The derailer element is the movable part of a derailer and no model class strictly speaking.

Used for expressing concepts like: the derailer has to be in the non-derailing position.</rdfs:comment>
        <rdfs:label>DerailerElementAndPosition</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#LevelCrossingAndState -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#LevelCrossingAndState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inState_LevelCrossingAndState"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#refersToLevelCrossing"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>LevelCrossingAndState</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#LockoutAreaAndState -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#LockoutAreaAndState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inState_LockoutAreaAndState"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#refersToLockoutArea_LockoutAreaAndState"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#LockoutArea"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>LockoutAreaAndState</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#LozAndState -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#LozAndState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#appliesToLoz"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Local_operating_area#LocalOperatingZone"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inState_LozAndState"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>LozAndState</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableElementAndPosition -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableElementAndPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#refersToMovableElement_MovableElementAndPosition"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>normal
If normal=true: the given position is the &lt;b&gt;normal &lt;/b&gt;position (the other position is the &lt;b&gt;reverse &lt;/b&gt;position).
If this attribute isn&apos;t given, then neither normal nor reverse position is defined.</rdfs:comment>
        <rdfs:comment>preferred
If preferred=true: the given position is the &lt;b&gt;preferred &lt;/b&gt;position (the position to which the movable element returns when no longer claimed by a route).
If this attribute isn&apos;t given, then there is no preferred position.</rdfs:comment>
        <rdfs:label>MovableElementAndPosition</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableSystemElementAndPosition -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableSystemElementAndPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableElementAndPosition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inState_MovableSystemElementAndPosition"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>MovableSystemElementAndPosition</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#OtherAssetAndState -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#OtherAssetAndState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#assetDescription"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>OtherAssetAndState</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#PointElementAndPosition -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#PointElementAndPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableElementAndPosition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inPosition_PointElementAndPosition"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A pair (point element, position).

The point element is the movable part of a point and no model class strictly speaking.

The positions that a point can adopt are left or right. Three-way points are rare and modelled as two consecutive points.</rdfs:comment>
        <rdfs:label>PointElementAndPosition</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SectionAndVacancy -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SectionAndVacancy">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inVacancyState"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#refersToTdsSection"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>SectionAndVacancy</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SignalAndMessage">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#appliesToSignal_SignalAndMessage"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#showsMessage"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A pair (signal, message). 
When instantiated, this provides a list of all possible (signal, message) pairs needed for constructing signal plans. Pairs that are not in the list are disallowed.</rdfs:comment>
        <rdfs:label>SignalAndMessage</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#StdCondition -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#StdCondition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#Condition"/>
        <rdfs:comment>A condition in a State Transition Diagram is a boolean condition that triggers a transition from start-state to target-state.</rdfs:comment>
        <rdfs:label>StdCondition</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SystemState -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SystemState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:comment>A set of (asset,state) pairs that describes the state of the signalling system.</rdfs:comment>
        <rdfs:label>SystemState</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#TpsAndState -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#TpsAndState">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#inState_TpsAndState"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>TpsAndState</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Building -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Building">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing"/>
        <rdfs:comment>A larger building, not necessarily purpose-built for signalling, that can house cabinets or equipment rooms
NR: a signal box maps to a building.</rdfs:comment>
        <rdfs:label>Building</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Cabinet -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Cabinet">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing"/>
        <rdfs:comment>A casing for active electronic components and wiring. Size can vary from cupboard to shoebox size.
Indoor cabinets are typically housed within a container or a building. Outdoor cabinets are mounted on a post or on the ground.
As opposed to an equipment room, a person cannot enter into a cabinet. Known in the UK as (location) cabinet or case.</rdfs:comment>
        <rdfs:label>Cabinet</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#CabinetGroup -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#CabinetGroup">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Cabinet"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#numberOfCabinets"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>CabinetGroup</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#CivilStructure -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#CivilStructure">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentSupport"/>
        <rdfs:comment>Civil engineering object known in a (external) data base, e.g. an asset management system for bridges, tunnels and other rail infrastructure.</rdfs:comment>
        <rdfs:label>CivilStructure</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Container -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Container">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing"/>
        <rdfs:comment>A large shippable box. Typically prefabricated and wired in a factory and shipped to site.</rdfs:comment>
        <rdfs:label>Container</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#ControlRoom -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#ControlRoom">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentRoom"/>
        <rdfs:comment>A space fitted with operation control and command equipment.</rdfs:comment>
        <rdfs:label>ControlRoom</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#ElectricProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#ElectricProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#usesNominalVoltage"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#maxPowerConsumption"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>ElectricProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentHouse -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentHouse">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Building"/>
        <rdfs:comment>A trackside (purpose-built) housing for signalling equipment.
de-DE: Schalthaus
nl-NL: relaishuis</rdfs:comment>
        <rdfs:label>EquipmentHouse</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentRoom -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentRoom">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing"/>
        <rdfs:comment>Room inside a building or a purpose-built trackside housing.</rdfs:comment>
        <rdfs:label>EquipmentRoom</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentSupport -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentSupport">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:comment>Generalization of fixings and housings, defined as civil structures that can support (or house) signalling equipment.</rdfs:comment>
        <rdfs:label>EquipmentSupport</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Fixing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Fixing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentSupport"/>
        <rdfs:comment>Allows to either simply state the type of the supporting fixing or explicitly instantiate the fixing.</rdfs:comment>
        <rdfs:comment>Generic term for a line-side structure that supports signalling equipment or another fixing. For instance:
- Fixing Post supports frame Sign.
- Fixing Foundation supports fixing Post.
- Fixing Rail supports fixing Cantilever.</rdfs:comment>
        <rdfs:label>Fixing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentSupport"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#isSupportedByFixingType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Describes the housing, ranging from a control centre building to a keybox mounted on a trackside post. 
Can be used if the type of housing is (yet) unknown, e.g. during an early design phase. Can also be used if the type of housing does not fit any of the available subtypes.</rdfs:comment>
        <rdfs:label>Housing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#OverheadLineMast -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#OverheadLineMast">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Fixing"/>
        <rdfs:label>OverheadLineMast</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Panel -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Panel">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing"/>
        <rdfs:comment>A panel to which switching equipment such as key release instruments or other control equipment can be affixed.
May be mounted indoors. When outdoors, it is typically fixed to a post and covered by a simple roof.</rdfs:comment>
        <rdfs:label>Panel</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#BlockedTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#BlockedTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RestrictedArea"/>
        <rdfs:comment>Access is only possible by special procedure, similar to shunting.</rdfs:comment>
        <rdfs:label>BlockedTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#BufferStop -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#BufferStop">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#VehicleStop"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#isOfBufferStopType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>BufferStop</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#ConstructionArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#ConstructionArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RestrictedArea"/>
        <rdfs:comment>Track area under construction.</rdfs:comment>
        <rdfs:label>ConstructionArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#DerailmentContainment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#DerailmentContainment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway"/>
        <rdfs:label>DerailmentContainment</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#ExpansionJoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#ExpansionJoint">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#isLocatedAt_ExpansionJoint"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#isLocatedOnRail"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#VehicleStop"/>
        <rdfs:comment>A rail component designed to absorb lengthening or shortening of rail, for instance thermal expansion.</rdfs:comment>
        <rdfs:label>ExpansionJoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Friction -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Friction">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#coefficient"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RestrictedArea"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialGauge"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackDesignation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway"/>
        <rdfs:label>Friction</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#InfrastructureBorder -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#InfrastructureBorder">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#isLocatedAt_InfrastructureBorder"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty"/>
        <rdfs:comment>Spot where the infrastructure managers assets end. The working direction points towards the IM territory. Beyond is uncharted territories. Hic Leones Sunt.</rdfs:comment>
        <rdfs:label>InfrastructureBorder</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#MainTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#MainTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType"/>
        <rdfs:comment>Main track in a station under control of an interlocking &lt;i&gt;as opposed to &lt;/i&gt;open line.
NR: Passengerline, thick line on drawing</rdfs:comment>
        <rdfs:label>MainTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#OpenLineTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#OpenLineTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType"/>
        <rdfs:comment>Section of track on open line, i.e. not controlled by an interlocking.</rdfs:comment>
        <rdfs:label>OpenLineTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RemovedTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RemovedTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RestrictedArea"/>
        <rdfs:comment>Area removed or earmarked for removal. At some stage during the construction process the track is physically removed but the (topological) information about the area is retained so that it can still be shown in the diagrams or  restored at a later stage, e.g. after track bed renewal.</rdfs:comment>
        <rdfs:label>RemovedTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RestrictedArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RestrictedArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialGauge"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackDesignation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway"/>
        <rdfs:comment>Track area not usable for normal operation &lt;i&gt;over longer periods&lt;/i&gt;. Construction activities are planned or taking place. The process and the time frames when activities take place are separated from the area.
NR: Track area under possession, SDEF blue area during a given time frame</rdfs:comment>
        <rdfs:label>RestrictedArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SandHump -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SandHump">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#VehicleStop"/>
        <rdfs:comment>A sand hump, drag or other pile of sand designed to stop an overrunning vehicle.
Do not use the attribute isOfVehicleStopType when using sand hump.</rdfs:comment>
        <rdfs:label>SandHump</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SecondaryTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SecondaryTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType"/>
        <rdfs:comment>Tracks marked secondary.
NR: freight, shows as dotted line in operations drawing.</rdfs:comment>
        <rdfs:label>SecondaryTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#ShuntingTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#ShuntingTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType"/>
        <rdfs:comment>Tracks used for shunting
DB: not used as a special track type</rdfs:comment>
        <rdfs:label>ShuntingTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SidingTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SidingTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType"/>
        <rdfs:comment>Track not considered part of the main infrastructure
NR: used for shunting</rdfs:comment>
        <rdfs:label>SidingTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SlabTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SlabTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway"/>
        <rdfs:comment>Concrete, ballastless track bed.
de-DE: feste Fahrbahn</rdfs:comment>
        <rdfs:comment>isFloating
The concrete slab to which the rails are affixed is supported by a flexible layer that attenuates elastic waves.
Need not to be filled in if irrelevant to signalling or unknown.</rdfs:comment>
        <rdfs:label>SlabTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SleeperTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SleeperTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#hasSleepersMadeOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Track with sleepers resting on ballast.</rdfs:comment>
        <rdfs:label>SleeperTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialGauge -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialGauge">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackDesignation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialStructureGauge"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialTrackGauge"/>
        </owl:disjointUnionOf>
        <rdfs:comment>Area(s) where a non-standard gauge applies. Standard gauges can be found in the national domain or indicated by reference drawings.</rdfs:comment>
        <rdfs:label>SpecialGauge</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialStructureGauge -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialStructureGauge">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialGauge"/>
        <rdfs:comment>The structure gauge is the outline within which there are no obstacles.</rdfs:comment>
        <rdfs:label>SpecialStructureGauge</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialTrackGauge -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialTrackGauge">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialGauge"/>
        <rdfs:comment>Area with non-standard track gauge, i.e. other than 1435 mm. Track gauge is the distance between the rails.</rdfs:comment>
        <rdfs:label>SpecialTrackGauge</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackDesignation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackDesignation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway"/>
        <rdfs:comment>Name of the section that the signaller can refer to for operational purpose (e.g. track 1/2) or a name that appears on signalling plans.
Use the Designation class inherited from the Configured Base Object to set the name.
en-GB: line name</rdfs:comment>
        <rdfs:label>TrackDesignation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:comment>Abstract super class for areas of track with particular properties.</rdfs:comment>
        <rdfs:label>TrackProperty</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackType">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway"/>
        <rdfs:comment>Operational classification that applies to track.
In case no suitable specialisation of this class is available, instantiate a TrackType with an appropriate Annotation or Description inherited from the Configured Base Object and that describes the needed type.</rdfs:comment>
        <rdfs:label>TrackType</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#Trackway">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#TrackProperty"/>
        <rdfs:comment>Type of track, given if relevant for mounting signalling equipment.</rdfs:comment>
        <rdfs:label>Trackway</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#VehicleStop -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#VehicleStop">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:comment>Installation for physically stopping trains. The track may continue beyond the device.</rdfs:comment>
        <rdfs:label>VehicleStop</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#AudioFrequencyTrackCircuit -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#AudioFrequencyTrackCircuit">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitSection"/>
        <rdfs:label>AudioFrequencyTrackCircuit</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#AxleCountingHead -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#AxleCountingHead">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#separatePowerAndData"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>AxleCountingHead</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#AxleCountingSection -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#AxleCountingSection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#isOfResetStrategyType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>An Axle counting system detects rolling stock in a logical section by counting incoming and outgoing wheels.</rdfs:comment>
        <rdfs:label>AxleCountingSection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#AxleCountingSectionConfiguration -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#AxleCountingSectionConfiguration">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSectionConfiguration"/>
        <rdfs:label>AxleCountingSectionConfiguration</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#Bond -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#Bond">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcConnector"/>
        <rdfs:comment>A cable needed for the correct functioning of train detection and traction current return.
Bonds connect pieces of track and are designed to (dis)allow:
&lt;ul&gt;
	&lt;li&gt;traction return current&lt;/li&gt;
	&lt;li&gt;train detection signal&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>Bond</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#DcVoltageTrackCircuit -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#DcVoltageTrackCircuit">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitSection"/>
        <rdfs:label>DcVoltageTrackCircuit</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#DepressionBar -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#DepressionBar">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor"/>
        <rdfs:label>DepressionBar</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#EMSensor -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#EMSensor">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#numberOfHeads"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>EMSensor</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#ElectricJoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#ElectricJoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponent"/>
        <rdfs:comment>Limit of a audio frequency section.
The rail isn&apos;t cut.</rdfs:comment>
        <rdfs:label>ElectricJoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#FtgsTrackCircuit -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#FtgsTrackCircuit">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#AudioFrequencyTrackCircuit"/>
        <rdfs:label>FtgsTrackCircuit</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#FtgsTrackCircuitProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#FtgsTrackCircuitProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitProperties"/>
        <rdfs:comment>Properties that apply to the FTG S track circuit.
Cut section length E1, E2, E3 are given only if there are at least 2,3 or 4 cut sections.</rdfs:comment>
        <rdfs:label>FtgsTrackCircuitProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#HviTrackCircuit -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#HviTrackCircuit">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitSection"/>
        <rdfs:label>HviTrackCircuit</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#ImpedanceBond -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#ImpedanceBond">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#Bond"/>
        <rdfs:comment>A choke (coil) that filters certain frequencies. This separates TC signals from traction currents.
&lt;ul&gt;
	&lt;li&gt;de-DE: Drosselspule&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>ImpedanceBond</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#InsulatedRailJoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#InsulatedRailJoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#singleRail_InsulatedRailJoint"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Electric (galvanic) separation joint. The rail is cut.
These joints can be situated at the extremity of a track circuit. 
They are also used &lt;i&gt;inside &lt;/i&gt;TDS sections, where they do not limit a track circuit. For instance point sections where track return current needs a change of the earth rail.</rdfs:comment>
        <rdfs:label>InsulatedRailJoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#Loop -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#Loop">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#singleDoubleTriple"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Loop</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#LowFrequencyTrackCircuit -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#LowFrequencyTrackCircuit">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitSection"/>
        <rdfs:label>LowFrequencyTrackCircuit</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#LowFrequencyTrackCircuitProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#LowFrequencyTrackCircuitProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitProperties"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#hasInfluencedLength"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>LowFrequencyTrackCircuitProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcConnector -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcConnector">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#connectsToRail"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#cableType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcFeederReceiverElement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehiclePassageDetector"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#Bond"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcFeedingReceivingCable"/>
        </owl:disjointUnionOf>
        <rdfs:label>TcConnector</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcFeederReceiverElement -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcFeederReceiverElement">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#connectsToRailVia"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcFeedingReceivingCable"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#isLocatedAt_TcFeederReceiverElement"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#isOfFeederReceiverType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehiclePassageDetector"/>
        <rdfs:comment>Track side devices for feeding AC signals into and receiving the same from track circuits. 
A feeder and receiver can share a spot location.</rdfs:comment>
        <rdfs:label>TcFeederReceiverElement</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcFeedingReceivingCable -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcFeedingReceivingCable">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcConnector"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#bondsTrackCircuit"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitSection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#feeding"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A cable that feeds signals into or receives signals from the track circuit.</rdfs:comment>
        <rdfs:label>TcFeedingReceivingCable</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcSensor -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcSensor">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor"/>
        <rdfs:label>TcSensor</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcSensorCombined -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcSensorCombined">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcSensor"/>
        <rdfs:label>TcSensorCombined</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponent -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponent">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehiclePassageDetector"/>
        <rdfs:comment>Line-side component of a train detection installation, typically a rail joint or axle counter head. 
It is located at a spot location at one TVP boundary, i.e. the spot up to where the train detection can safely detect train vacancy. The TVP section extremities must coincide exactly with these spot locations.</rdfs:comment>
        <rdfs:label>TdsComponent</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponentConfiguration -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponentConfiguration">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAssetConfiguration"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#appliesToTdsComponent"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#canBeActivated"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A set of properties that applies to a TDS component. The set of properties can be extended, e.g. for supplier-defined properties.</rdfs:comment>
        <rdfs:label>TdsComponentConfiguration</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsOccupancyOverrideGroup -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsOccupancyOverrideGroup">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TriggerAssignment"/>
        <rdfs:comment>A set of TDS sections for which the occupancy status can be overridden (a degraded mode operational procedure).
The override procedure allows the signaller to open a signal that is closed because the TDS section reports (presumably false) occupied.</rdfs:comment>
        <rdfs:label>TdsOccupancyOverrideGroup</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSection -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#VirtualTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#appliesToTvpSection_TdsSection"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TvpSection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TvpSection"/>
        <rdfs:comment>A logical section of the train detection system.
The section is associated with a TVP section.</rdfs:comment>
        <rdfs:label>TdsSection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSectionConfiguration -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSectionConfiguration">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAssetConfiguration"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#appliesToTdsSection"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A set of properties that applies to a TDS section.
The class &lt;a href=&quot;$element://{7B328390-6A51-4bc6-A2A2-1B6DAAB21DA4}&quot;&gt;&lt;font color=&quot;#0000ff&quot;&gt;&lt;u&gt;insulated rail joint&lt;/u&gt;&lt;/font&gt;&lt;/a&gt; informs which rail is cut for insulation.</rdfs:comment>
        <rdfs:comment>isOverridable
True when the associated section is configured to allow override.
The override procedure allows the signaller to open a signal that is closed because the TDS section reports (presumably false) occupied.</rdfs:comment>
        <rdfs:label>TdsSectionConfiguration</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:comment>ballastResistance
Resistance of the track bed of the section (Ohm per km). Given if the train detection technology is a track circuit.
Can be used when calculating the maximum length of the track circuit.</rdfs:comment>
        <rdfs:label>TrackCircuitProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitSection -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TrackCircuitSection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#hasTcFeederReceiver"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcFeederReceiverElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A train detection system that detects rolling stock axles shunting the rails.</rdfs:comment>
        <rdfs:label>TrackCircuitSection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#Treadle -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#Treadle">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor"/>
        <rdfs:comment>Detector of train passage. The treadle can be electronic or mechanical. 
The working direction of the treadle can be given by the spot location&apos;s application direction.</rdfs:comment>
        <rdfs:label>Treadle</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TriggerAssignment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TriggerAssignment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:comment>Assigns a trigger to vehicle detection.
The trigger is typically a Vehicle Passage Detector. It can also be an approach zone, either all sections or only the extremity. Even if no train detection is given, a condition can still apply.
NR: strike-in or strike-out; the trigger is closely associated with vehicle detection</rdfs:comment>
        <rdfs:comment>functionDescription
Describes the triggering action, e.g. &lt;i&gt; &quot;Activate the level crossing at km x.y&quot;&lt;/i&gt;. The description is subject to national rules and regulations.</rdfs:comment>
        <rdfs:label>TriggerAssignment</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TvpSection -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TvpSection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#VirtualTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#isLocatedAt_TvpSection"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Section of track that must be proven vacant for safe train operations. Vacancy proving is accomplished either by a TDS or by procedure.</rdfs:comment>
        <rdfs:label>TvpSection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TvpSectionConfiguration -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TvpSectionConfiguration">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAssetConfiguration"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#appliesToTvpSection_TvpSectionConfiguration"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TvpSection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#berthingTrack"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A set of properties that applies to a TVP section.</rdfs:comment>
        <rdfs:label>TvpSectionConfiguration</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehiclePassageDetector -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehiclePassageDetector">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponent"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor"/>
        </owl:disjointUnionOf>
        <rdfs:comment>Line-side device for detecting passage of a rail vehicle.
en-GB: strike-in or strike-out detector.</rdfs:comment>
        <rdfs:label>VehiclePassageDetector</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehiclePassageDetector"/>
        <rdfs:comment>Vehicle-worked actuator: line-side installation that senses vehicle passage and subsequently switches other equipment. This class can be instantiated in case no appropriate subtype is available or the type is unknown during design.</rdfs:comment>
        <rdfs:label>VehicleSensor</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsDeadlockSectionGroup -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsDeadlockSectionGroup">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRoute"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRouteTrigger"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsSignalGroup"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#AutomaticRouteSettingSystem"/>
        <rdfs:comment>Set of TVP sections used for deadlock checking (AND checking).</rdfs:comment>
        <rdfs:label>ArsDeadlockSectionGroup</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRoute -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRoute">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#evaluatesSectionGroup"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsDeadlockSectionGroup"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ownsArsRouteTrigger"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRouteTrigger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRouteTrigger"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsSignalGroup"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#AutomaticRouteSettingSystem"/>
        <rdfs:comment>A route as known in the interlocking plus parameters used to configure the route request.</rdfs:comment>
        <rdfs:label>ArsRoute</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRouteTrigger -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRouteTrigger">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ownsSpeedDependentDelay"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsSpeedCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#refersToDistantSignal"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsSignalGroup"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#AutomaticRouteSettingSystem"/>
        <rdfs:label>ArsRouteTrigger</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsSignalGroup -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsSignalGroup">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#AutomaticRouteSettingSystem"/>
        <rdfs:label>ArsSignalGroup</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsSpeedCategory -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsSpeedCategory">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#describedBySpeed"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#hasTriggerDelay"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>ArsSpeedCategory</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#AutomaticRouteSettingSystem -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#AutomaticRouteSettingSystem">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#isConnectedToTrDrSystem"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_describer#TrainDescriberSystem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ownsArsRoute"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRoute"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ownsArsSignalGroup"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsSignalGroup"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#refersToCentralInterlocking"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#CentralInterlocking"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The automatic route Setting (ARS) system requests ARS routes.</rdfs:comment>
        <rdfs:label>AutomaticRouteSettingSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#Cable -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#Cable">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointInstallation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteNode"/>
        <rdfs:comment>Cable, wire or core. 
A cable provides the physical connection.</rdfs:comment>
        <rdfs:label>Cable</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableBridge -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableBridge">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute"/>
        <rdfs:label>CableBridge</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableDistributorDisconnector -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableDistributorDisconnector">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointInstallation"/>
        <rdfs:comment>Cable distributor is a device where one set of cables terminates and (mostly) connect to another greater set of cables that lead to other terminators.
Typically &lt;u&gt;housed &lt;/u&gt;in a track side cable disconnection box (lineside &quot;mushroom&quot; disconnection box).
Often contains a disconnector.
NR: Cable disconnector</rdfs:comment>
        <rdfs:label>CableDistributorDisconnector</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#realisesCableJoints"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointRelation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointRelation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableProperties"/>
        <rdfs:comment>A cable joint is where cable terminations are distributed, joined, spliced.
As opposed to the cable joint installation, the cable joint is not housed. The linear location of the cables provide the position inside the cable route.</rdfs:comment>
        <rdfs:label>CableJoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointInstallation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointInstallation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#containsCableJoint"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointRelation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#isHousedIn_CableJointInstallation"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteNode"/>
        <rdfs:comment>Device where one set of &lt;i&gt;n&lt;/i&gt; cables/wires terminates and connects to another set of &lt;i&gt;m&lt;/i&gt; cables/wires.
Number &lt;i&gt;n&lt;/i&gt; is not necessarily equal to &lt;i&gt;m&lt;/i&gt;.</rdfs:comment>
        <rdfs:label>CableJointInstallation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointRack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointRack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointInstallation"/>
        <rdfs:comment>A rack in the field where cables arrive and cores are dispatched to endpoints.</rdfs:comment>
        <rdfs:label>CableJointRack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointRelation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointRelation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#joinsCableA"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#Cable"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#joinsCableB"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#Cable"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableProperties"/>
        <rdfs:comment>Individual relation between two cables. Describes a logical tie between cable A and B.</rdfs:comment>
        <rdfs:label>CableJointRelation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CablePipe -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CablePipe">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute"/>
        <rdfs:label>CablePipe</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CablePit -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CablePit">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteJunctionNode"/>
        <rdfs:label>CablePit</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#isOfCoreType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#category"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>CableProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PhysicalObject"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#isLocatedAt_CableRoute"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#isMadeOfMaterial_CableRoute"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteNode"/>
        <rdfs:comment>Linear structure for guiding cables.</rdfs:comment>
        <rdfs:label>CableRoute</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteExit -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteExit">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteJunctionNode"/>
        <rdfs:label>CableRouteExit</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteJoin -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteJoin">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteJunctionNode"/>
        <rdfs:label>CableRouteJoin</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteJunctionNode -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteJunctionNode">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteNode"/>
        <rdfs:comment>A physical node in the cable route network where cables can enter/exit a cable route. From this hub the cable route goes to controller, controlled track asset, cable distributor or housing.
This class can be instantiated if no appropriate specialised class is available, for instance at an early planning stage.</rdfs:comment>
        <rdfs:label>CableRouteJunctionNode</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteNode -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteNode">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteJunctionNode"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteTerminationNode"/>
        </owl:disjointUnionOf>
        <rdfs:label>CableRouteNode</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteTerminationNode -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteTerminationNode">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteNode"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#refersToTerminalElement"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#TerminalElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>CableRouteTerminationNode</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableTerminationRack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableTerminationRack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointInstallation"/>
        <rdfs:comment>A rack in the relay room/signal box where field cables arrive and cores are dispatched to the interlocking or other systems.</rdfs:comment>
        <rdfs:label>CableTerminationRack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableTray -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableTray">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute"/>
        <rdfs:label>CableTray</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableTrench -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableTrench">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute"/>
        <rdfs:label>CableTrench</rdfs:label>

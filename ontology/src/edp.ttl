        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#SystemState> a owl:Class ;
    rdfs:label "SystemState" ;
    rdfs:comment "A set of (asset,state) pairs that describes the state of the signalling system." ;

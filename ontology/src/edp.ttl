<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#OverheadLineGap> a owl:Class ;
    rdfs:label "OverheadLineGap" ;
    rdfs:comment """A gap in the overhead traction. 
A bascule bridge would typically have a gap with open wire and no type.""",
        """wired
Indicates whether a (neutral) line is present.
<ul>
	<li>true: the pantograph must be lowered.</li>
	<li>false: no need to lower the pantograph.</li>
</ul>""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#wired> ;
            owl:someValuesFrom xsd:boolean ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationGap> .


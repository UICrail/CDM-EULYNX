<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#SignallingEquivalentUnit> a owl:Class ;
    rdfs:label "SignallingEquivalentUnit" ;
    rdfs:comment """Signalling Equivalent Unit (SEU) is a way of estimating the size of a signalling project; This determines if  a piece of equipment is counted as an SEU or part of one.
E.g. a signal &amp; a point are 1 SEU each regardless complexity and components.""",
        """rate
The SEU rate.
Allows weighting the cost of the asset for accounting purposes.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#rate> ;
            owl:someValuesFrom xsd:decimal ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfigurationProperty> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#EquipmentLocation> .


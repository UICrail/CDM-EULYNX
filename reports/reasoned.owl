    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/DB/Route#RouteSignalling -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/DB/Route#RouteSignalling">

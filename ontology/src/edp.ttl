<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#PointController> a owl:Class ;
    rdfs:label "PointController" ;
    rdfs:comment """Controller for movable elements.
The number of point machines is registered in the movable component configuration and is the sum of number of drives and external detectors.""" ;

                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#PhysicalInputChannel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>DoubleLogicalInputChannel</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#DoubleLogicalOutputChannel -->


        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#TerminalElement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#VerticalAligmentSegment"/>
        <rdfs:comment>A set of tracks in a given area that all use the same linear positioning system. This is an operational grouping.</rdfs:comment>
        <rdfs:comment>capacity
The number of trains per hour for which this line is designed.</rdfs:comment>
        <rdfs:label>Line</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#LinearElement -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#LinearElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/topology/topo#LinearElement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#PositionedRelationSet"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#RegisteredIntrinsicCoordinate"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#TerminalElement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#VerticalAligmentSegment"/>
        <rdfs:label>LinearElement</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#PositionedRelationSet -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#PositionedRelationSet">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#RegisteredIntrinsicCoordinate"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#TerminalElement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#VerticalAligmentSegment"/>
        <rdfs:comment>Class for enriching the RSM positioned relation with configuration properties such as designation and applicable rule set.</rdfs:comment>
        <rdfs:label>PositionedRelationSet</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#PostProcessingInformation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#PostProcessingInformation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:comment>Information about corrections that were applied to the data during the planning process. This excludes processing at the moment of observation and storage of the original data set.</rdfs:comment>
        <rdfs:label>PostProcessingInformation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#RegisteredIntrinsicCoordinate -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#RegisteredIntrinsicCoordinate">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#atPort"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#atPort"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#atPort"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">4</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#TerminalElement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#VerticalAligmentSegment"/>
        <rdfs:comment>A point stored in a GIS with an address. The point is typically situated at the ends of alignment segments. Used for track and line alignment.   
de-DE: GEO_Knoten</rdfs:comment>
        <rdfs:label>RegisteredIntrinsicCoordinate</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#TerminalElement -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#TerminalElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#isOfTerminusType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#refersToRsmNavigability_TerminalElement"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#VerticalAligmentSegment"/>
        <rdfs:comment>A dangling end of the (known) topology; a leaf of the topology graph.</rdfs:comment>
        <rdfs:label>TerminalElement</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#VerticalAligmentSegment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#VerticalAligmentSegment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#refersToRsmVerticalAlignmentSegment"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>VerticalAligmentSegment</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Actor -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Actor">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#DataRelease"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Organisation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#PlanningCorrection"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageGroupMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#StatusInformation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#TimeFrame"/>
        <rdfs:comment>A party, typically a person and his/her contact data, who participates in the planning creation process.
The fields can be filled as far as privacy rules allow. For instance, NR only uses initials on plans, while SCNF requires full name and initials.</rdfs:comment>
        <rdfs:label>Actor</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Changes -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Changes">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:comment>Change-set that explicitly lists the objects that are subject to change. Can also be revealed by comparison of initial and final state.</rdfs:comment>
        <rdfs:label>Changes</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#DataRelease -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#DataRelease">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#discipline_DataRelease"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Organisation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#PlanningCorrection"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageGroupMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#StatusInformation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#TimeFrame"/>
        <rdfs:comment>A set of objects plus information about planned changes to these objects.
de-DE: Ausgabe Fachdaten</rdfs:comment>
        <rdfs:label>DataRelease</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#DeltaDataRelease -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#DeltaDataRelease">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#DataRelease"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#finalState"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Data_container#DataContainer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#initialState"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Data_container#DataContainer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A delta release of engineering data reveals changes by comparing the initial state with the final state. 
The subset of engineering data can be restricted to a given subject matter.
The engineering data are separated from the organisational meta-data.
de-DE: Ausgabe Fachdaten</rdfs:comment>
        <rdfs:comment>XOR</rdfs:comment>
        <rdfs:label>DeltaDataRelease</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Organisation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Organisation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#name_Organisation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#PlanningCorrection"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageGroupMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#StatusInformation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#TimeFrame"/>
        <rdfs:comment>The business contact data within an organisation.</rdfs:comment>
        <rdfs:label>Organisation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#PlanningCorrection -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#PlanningCorrection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#hasCorrectedProjectStage"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#isBasedOnProjectStage"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#basedOnProjectStage"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#correctionType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageGroupMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#StatusInformation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#TimeFrame"/>
        <rdfs:comment>Class that allows highlighting the differences between a approved data release and a revised data release. This helps V&amp;amp;V staff evaluate the desired corrections.</rdfs:comment>
        <rdfs:comment>basedOnProjectStage
Human-readable designation of a project stage that was the basis for this correction.
This may be an external file not delivered in the present file.</rdfs:comment>
        <rdfs:comment>correctionType
The type of correction, indicating the severity of the change. This acts as a hint to the kind of attention that V&amp;amp;V should pay.
de-DE: &amp;#196;nderungsmitteilung</rdfs:comment>
        <rdfs:label>PlanningCorrection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectMetaData -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectMetaData">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#knowsOrganisation"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Organisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#splitsIntoGroupMetaData"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageGroupMetaData"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#projectDesignation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageGroupMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#StatusInformation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#TimeFrame"/>
        <rdfs:comment>Organisational and subject meta-data that apply globally to planning groups within a project stage.
de-DE: LST Planung Projekt</rdfs:comment>
        <rdfs:label>ProjectMetaData</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageGroupMetaData -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageGroupMetaData">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#hasRequirementSpecification"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Attachment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#splitsIntoStageMetaData"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#StatusInformation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#TimeFrame"/>
        <rdfs:comment>Meta-data informing a group of project stages. Stages are grouped to reflect common qualities such as:
&lt;ul&gt;
	&lt;li&gt;allocation to consulting engineering firm (e.g. stages x-y by ACME railway engineering GmbH).&lt;/li&gt;
&lt;/ul&gt;
&lt;ul&gt;
	&lt;li&gt;area&lt;/li&gt;
	&lt;li&gt;discipline (aka subject matter), e.g. geo, interlocking, ETCS&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>ProjectStageGroupMetaData</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#hasStatusInformation"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#StatusInformation"/>

        <rdfs:label>PassengerTrain</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#SpeedProfile -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#SpeedProfile">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#TrainCategory"/>
        <rdfs:comment>A speed profile represents the maximum speed along a defined and delimited path through the railway network. 
The origin of the profile is situated at the signal plus a positive or negative offset.  
The profile has one or more of sections, each of given length and with given maximum speed. 
This approach is equivalent to the ETCS SSP.</rdfs:comment>
        <rdfs:label>SpeedProfile</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#SpeedSegment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#SpeedSegment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Segment"/>
        <rdfs:comment>A segment of a speed profile for which a constant speed applies.</rdfs:comment>
        <rdfs:label>SpeedSegment</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#TemporarySpeedRestriction -->


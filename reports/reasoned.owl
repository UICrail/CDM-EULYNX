        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Common#hasStallDetection"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Technical installation that detects hazards, flooding, fire, stalled trains, in a tunnel. The interlocking uses this information to (dis-)allow trains entering the tunnel.</rdfs:comment>
        <rdfs:label>TunnelTechnicalInstallation</rdfs:label>
    </owl:Class>
    



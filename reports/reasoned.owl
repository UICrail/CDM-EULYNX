            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Timer value for a tunnel-technical installation (TTI)</rdfs:comment>
        <rdfs:label>TunnelSignalTimer</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Common#TunnelTechnicalInstallation -->


    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsProtectionDistance> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningSystem> a owl:Class ;
    rdfs:label "WarningSystem" ;
    rdfs:comment "Train-activated warning system that alerts line-side staff to impending danger." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Data_container#Topography> a owl:Class ;

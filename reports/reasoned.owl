            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#ghostTrainPropagationTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#shadowTrainTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Set of timers that apply to a set of physical train detection sections. 
Definitions are found in the &lt;a href=&quot;$inet://http://www.ertms.be/sites/default/files/2018-03/16E0421A_HL3.pdf&quot;&gt;&lt;font color=&quot;#0000ff&quot;&gt;&lt;u&gt;HL3 specification&lt;/u&gt;&lt;/font&gt;&lt;/a&gt;.</rdfs:comment>
        <rdfs:label>HL3SectionTimers</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#HybridLevel3Timers -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#HybridLevel3Timers">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#muteTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#waitIntegrityTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#NonStoppingPoint"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#PlatformNonStoppingLocation"/>
        <rdfs:comment>Set of timers for HL3 operation.
Paragraph 3.4.1 in the &lt;a href=&quot;$inet://http://www.ertms.be/sites/default/files/2018-03/16E0421A_HL3.pdf&quot;&gt;&lt;font color=&quot;#0000ff&quot;&gt;&lt;u&gt;HL3 specification&lt;/u&gt;&lt;/font&gt;&lt;/a&gt;.
Waiting timers are implemented in the track side to avoid unnecessary changes in the state of a VSS due to the asynchronicity of train position, train integrity and TTD information.</rdfs:comment>
        <rdfs:label>HybridLevel3Timers</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#LevelCrossingMalfunction -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#LevelCrossingMalfunction">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#hasSpeedRestrictionArea"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#LxDepartureDetection"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#SignalDimmingGroup"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#TtiNotifications"/>
        <rdfs:comment>Parameters governing behaviour when the level crossing malfunctions.</rdfs:comment>
        <rdfs:label>LevelCrossingMalfunction</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#LxDepartureDetection -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#LxDepartureDetection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#hasDepartureDetectionPoint"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#hasSpeedRestrictionLength"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#SignalDimmingGroup"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#TtiNotifications"/>
        <rdfs:comment>Parameters for activating the level crossing by detection of departure of an ETCS-supervised train. 
nl-NL: vertrekdetectiepunt</rdfs:comment>
        <rdfs:label>LxDepartureDetection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#NonStoppingPoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#NonStoppingPoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#PlatformNonStoppingLocation"/>
        <rdfs:comment>A spot that the rear of a train must or should clear ( &quot;TAA&quot;)</rdfs:comment>
        <rdfs:label>NonStoppingPoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#NotCentralControlledAreaDepartureTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#NotCentralControlledAreaDepartureTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#DepartureTrack"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#refersToBaliseGroup_NotCentralControlledAreaDepartureTrack"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsBaliseGroup"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#hasMaxSpeed_NotCentralControlledAreaDepartureTrack"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>nl-NL: Een vertrekspoor NCBG in de context van ERTMS is een spoor waarbij een Movement Authority nodig is voor een vertrek op basis van een vervolgrijweg (in dezelfde richting of voor een kerende trein).</rdfs:comment>
        <rdfs:label>NotCentralControlledAreaDepartureTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#PlatformNonStoppingLocation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#PlatformNonStoppingLocation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#clearsPlatformEdge"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#UsablePlatformEdge"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#isLocatedAt_PlatformNonStoppingLocation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Indicates the spot location, near a platform, that the rear of trains must be capable of clearing.</rdfs:comment>
        <rdfs:label>PlatformNonStoppingLocation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#RequestedNonStoppingPoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#RequestedNonStoppingPoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#NonStoppingPoint"/>
        <rdfs:comment>A spot that a train, dependent on its length, should clear for operational purposes so that the object behind the train is cleared.</rdfs:comment>
        <rdfs:label>RequestedNonStoppingPoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#SignalDimmingGroup -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#SignalDimmingGroup">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#appliesDimmingPolicy"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#TtiNotifications"/>
        <rdfs:label>SignalDimmingGroup</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#TemporaryShuntingAreaDepartureTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#TemporaryShuntingAreaDepartureTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#DepartureTrack"/>
        <rdfs:comment>Departure track from a temporary shunting area.</rdfs:comment>
        <rdfs:label>TemporaryShuntingAreaDepartureTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#TtiNotifications -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#TtiNotifications">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#appliesToTti"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Common#TunnelTechnicalInstallation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>CSS is configured to exchange notifications with a tunnel technical installation.</rdfs:comment>
        <rdfs:label>TtiNotifications</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#VirtualSubSection -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#VirtualSubSection">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#disconnectPropagationTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#integrityLossPropagationTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A subdivision of the trackside train detection (TTD) used for positioning trains by means of reported position and length.</rdfs:comment>
        <rdfs:label>VirtualSubSection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#VssLimit -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#VssLimit">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsComponent"/>
        <rdfs:label>VssLimit</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#WeightLimitMarker -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#WeightLimitMarker">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsMarker"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#isOfTypeLorH"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#refersToLightSignal"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#LightSignal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Selective slow/stop-order for heavy freight trains. Used only in transition areas for connecting to legacy signalling.
NL: Een H- of L-lichtbak.</rdfs:comment>
        <rdfs:label>WeightLimitMarker</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#WorkzoneDepartureTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#WorkzoneDepartureTrack">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#DepartureTrack"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#hasMaxSpeed_WorkzoneDepartureTrack"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Departure track from a work zone.
nl-NL: Vertrekspoor van werkzone</rdfs:comment>
        <rdfs:label>WorkzoneDepartureTrack</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Local_operating_area#LozBridgeRelation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Local_operating_area#LozBridgeRelation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Local_operating_area#LozAssetRelation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Local_operating_area#appliesToMovableBridge"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableBridge"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The bridge is conditional to operating the local operating zone.</rdfs:comment>
        <rdfs:label>LozBridgeRelation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Local_operating_area#LozSignalRelation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Local_operating_area#LozSignalRelation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Local_operating_area#LozSignalRelation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Local_operating_area#isPassable"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>isPassable
True when the signal may be passed (white light).
False, red light, otherwise.</rdfs:comment>
        <rdfs:label>LozSignalRelation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#OnSightRoute -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#OnSightRoute">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#OnSightRoute"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#allowedWhenSectionOccupied"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>ProRail on-sight route
nl-NL: Rijden op zicht rijweg (ROZ)</rdfs:comment>
        <rdfs:comment>allowedWhenSectionOccupied
True: the on-sight route is possible even when the section in advance of the signal is already occupied.</rdfs:comment>
        <rdfs:label>OnSightRoute</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#Route -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#Route">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#Route"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#usedByRouteLevelType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Route</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#RouteBody -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#RouteBody">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#RouteBody"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#hasMovableOverheadLine"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>hasMovableOverheadLine
True if there&apos;s a movable overhead line, over a point or crossing (needed for checking the route conditions).

nl-NL: Een indicatie of een beweegbaar bovenleidingkruis in de route is opgenomen.</rdfs:comment>
        <rdfs:label>RouteBody</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#RouteSettingProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#RouteSettingProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RouteProperty"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#hasCargoCriteriumOption"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#hasExtraControlOption"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#hasNormalControlOption"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#hasStopSignalControlOption"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>hasCargoCriteriumOption
nl-NL: Geeft aan of bij de rijweg een goederen criterium kan worden opgegeven.</rdfs:comment>
        <rdfs:comment>hasExtraControlOption
nl-NL: Een indicatie dat de verhindering voor rijweginstelling van het beginsein van de route met een Extra Bediening genegeerd moet worden.</rdfs:comment>
        <rdfs:comment>hasNormalControlOption
nl-NL: Een indicatie of de route normaal instelbaar is.</rdfs:comment>
        <rdfs:comment>hasStopSignalControlOption
nl-NL: Een indicatie of de route met een Stoptonend Sein instelbaar is.</rdfs:comment>
        <rdfs:label>RouteSettingProperties</rdfs:label>
    </owl:Class>
    



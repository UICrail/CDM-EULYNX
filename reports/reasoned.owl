    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#TrainCategory -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#TrainCategory">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#FreightTrain"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#KvbTrain"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#PassengerTrain"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#TiltingTrain"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#TpwsTrain"/>
        </owl:disjointUnionOf>
        <rdfs:comment>Train category, such as freight, tilting, passenger, high speed. Can be expanded in national domains because ETCS category may not suffice.</rdfs:comment>
        <rdfs:label>TrainCategory</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Speed_profiles#TrainCategorySpeedProfile -->


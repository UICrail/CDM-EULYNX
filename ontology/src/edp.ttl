        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossing> a owl:Class ;
    rdfs:label "TrackCrossing" ;
    rdfs:comment "B&#220; Kreuzungspunkt",
        """Informs that vehicles or pedestrians cross railway tracks <i>at the same level</i>.
This class allows naming the street, road or path according to national rules (e.g. NR informs streetname nor type).
The track crossing can, <i>but need not</i>, be protected by a level crossing system.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#VirtualTrackAsset> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystem> .


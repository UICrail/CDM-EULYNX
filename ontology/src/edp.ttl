            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#isOfNormalisationType> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_low_voltage#scheme_PowerSupplyModuleType_EAID_4FF38D1F_CDF1_45df_B6E3_FDB282FC7718> a skos:ConceptScheme ;
    rdfs:label "PowerSupplyModuleType" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#NonPhysicalSignal> a owl:Class ;
    rdfs:label "NonPhysicalSignal" ;
    rdfs:comment """A signal without a physical line-side appearance. 
The non-physical signal need not send information to the train driver as opposed to a physical signal.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#AspectSet> a owl:Class ;
    rdfs:label "AspectSet" ;
    rdfs:comment """A set of active and/or passive aspects representing a message sent by a signal. 
Typically, the meaning of the message is defined in a rule book.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessage> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#Symbol> a owl:Class ;
    rdfs:label "Symbol" ;
    rdfs:subClassOf [ a owl:Restriction ;

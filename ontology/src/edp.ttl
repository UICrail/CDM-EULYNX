<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#DispatchPosition> a owl:Class ;
    rdfs:label "DispatchPosition" ;
    rdfs:comment "The spot from where trains can be dispatched, i.e. the spot where the dispatcher can sight train(s) and signals. Extra equipment like plungers can be installed here." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#isLocatedAt_DispatchPosition> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformAccess> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformFacility> a owl:Class ;
    rdfs:label "PlatformFacility" ;
    rdfs:comment """Allows passengers to board and alight from trains. Has one or more edges and passenger accesses.  
The platform designation is usually composed of the names of the platform edges,<i> </i>e.g. <i>Platform 3 and 4</i>. Sometimes, a name like <i>Platform A with tracks 102 and 103</i> may occur.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#hasPlatformAccess> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformAccess> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset> .


areaname + areatype + assetname + assettype

E.g.  areaname=&quot;Ut&quot;, areatype=&quot;Wisselgebied&quot;, assetname=&quot;41A&quot;, assettype=&quot;Wissel&quot;</rdfs:comment>
        <rdfs:label>Designation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Common#TunnelSignalTimer -->


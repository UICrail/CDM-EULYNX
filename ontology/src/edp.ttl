<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#RouteSettingProperties> a owl:Class ;
    rdfs:label "RouteSettingProperties" ;
    rdfs:comment """hasCargoCriteriumOption
nl-NL: Geeft aan of bij de rijweg een goederen criterium kan worden opgegeven.""",
        """hasExtraControlOption
nl-NL: Een indicatie dat de verhindering voor rijweginstelling van het beginsein van de route met een Extra Bediening genegeerd moet worden.""",
        """hasNormalControlOption
nl-NL: Een indicatie of de route normaal instelbaar is.""",
        """hasStopSignalControlOption
nl-NL: Een indicatie of de route met een Stoptonend Sein instelbaar is.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#hasStopSignalControlOption> ;
            owl:someValuesFrom xsd:boolean ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#hasCargoCriteriumOption> ;
            owl:someValuesFrom xsd:boolean ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#hasExtraControlOption> ;
            owl:someValuesFrom xsd:boolean ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Route#hasNormalControlOption> ;
            owl:someValuesFrom xsd:boolean ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RouteProperty> .


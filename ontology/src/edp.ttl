<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#HybridLevel3Timers> a owl:Class ;
    rdfs:label "HybridLevel3Timers" ;
    rdfs:comment """Set of timers for HL3 operation.
Paragraph 3.4.1 in the <a href="$inet://http://www.ertms.be/sites/default/files/2018-03/16E0421A_HL3.pdf"><font color="#0000ff"><u>HL3 specification</u></font></a>.
Waiting timers are implemented in the track side to avoid unnecessary changes in the state of a VSS due to the asynchronicity of train position, train integrity and TTD information.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#muteTime> ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#waitIntegrityTime> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#DepartureTrack>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#DepartureTrackExtension>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#NonStoppingPoint> .


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/TRV/Train_protection#AtcBalise -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/TRV/Train_protection#AtcBalise">

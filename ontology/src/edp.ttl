<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#LockCombination> a owl:Class ;
    rdfs:label "LockCombination" ;
    rdfs:comment """A combination of one master lock and a set of dependent locks.
Either the master lock or all dependent locks are unlocked.""" ;
    rdfs:subClassOf [ a owl:Restriction ;

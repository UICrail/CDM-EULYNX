    <owl:NamedIndividual rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#scheme_MovableElementPassableTypes_EAID_1866E02E_6D82_4bff_BD3A_3A29FA080A50">

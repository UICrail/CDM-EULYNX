        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Automatic_route_setting#SpadAlarm"/>
        <rdfs:comment>A grouping of sections where ARS monitors correct sequential operation.</rdfs:comment>
        <rdfs:label>SequenceMonitor</rdfs:label>

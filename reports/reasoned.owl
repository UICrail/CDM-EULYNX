            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The signal is presumed passed at danger (SPAD) when the given track circuit is unexpectedly detected occupied.</rdfs:comment>
        <rdfs:label>SpadAlarm</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Cabling#CableBridge -->


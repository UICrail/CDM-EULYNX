<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Block_system#BlockElement> a owl:Class ;
    rdfs:label "BlockElement" ;
    rdfs:comment """The extremity of the block system. A track equipped with a block system has two matching block elements.

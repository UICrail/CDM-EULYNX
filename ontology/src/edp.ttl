<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#UsablePlatformEdge> a owl:Class ;
    rdfs:label "UsablePlatformEdge" ;
    rdfs:comment """Where trains are allowed to stand.
Notes:
<ul>
	<li>NR and SNCF: ends at signal minus sighting distance.</li>
</ul>
<ul>
	<li>NR: platform standage.</li>
</ul>
<ul>
	<li>ProRail: bruikbare lengte.</li>
	<li>RFI only use operational platform edge.</li>
	<li>DB design rules consider the <i>usable </i>length only.</li>
</ul>""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge> .


<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsPacket> a owl:Class ;
    rdfs:label "EtcsPacket" ;
    rdfs:comment """ETCS packet as defined in subset-026.
Used by either balise telegrams or RBC messages.
The end-user can use an existing XSD to instantiate XML of ETCS packets. See for instance the openETCS project (<a href="$inet://https://github.com/openETCS/dataDictionary/blob/master/Artifacts/subset-026-7/Decoder/Delivery/SubsetFromWord/SubSet026_7.xml"><font color="#0000ff"><u>here)</u></font></a>.""",
        """number
The number of the the ETCS packet according to subset 026-7.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#number_EtcsPacket> ;
            owl:someValuesFrom xsd:integer ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#CantDeficiencySpeed>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsDangerpoint>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsEndOfAuthority>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsNationalValuePair>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsSrsVersion>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTextDisplayEndCondition>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTextDisplayStartCondition>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsTrainCategorySpeed>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#StandstillDetectionForShunting> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#LeuModule> a owl:Class ;
    rdfs:label "LeuModule" ;
    rdfs:comment "Hardware module for controlling Eurobalises." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#isPartOfLeuSystem> ;

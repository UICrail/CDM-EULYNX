<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor> a owl:Class ;
    rdfs:label "VehicleSensor" ;
    rdfs:comment "Vehicle-worked actuator: line-side installation that senses vehicle passage and subsequently switches other equipment. This class can be instantiated in case no appropriate subtype is available or the type is unknown during design." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehiclePassageDetector> .


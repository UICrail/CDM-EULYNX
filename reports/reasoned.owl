        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#NonStoppingPoint"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#PlatformNonStoppingLocation"/>
        <rdfs:comment>Extension area of a departure track.</rdfs:comment>
        <rdfs:label>DepartureTrackExtension</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#EtcsLevelCrossingSystem -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#EtcsLevelCrossingSystem">

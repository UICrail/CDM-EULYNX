<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#VirtualTrackAsset> a owl:Class ;
    rdfs:label "VirtualTrackAsset" ;
    rdfs:comment """An intangible asset.
Virtual track assets can be composed of or derived from physical track assets. They may be displayed on the signaller's user interface.
Logical entities such as routes are transient, thus not considered track assets.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAsset> .


<?xml version="1.0"?>
<rdf:RDF xmlns="https://cdm.ovh/edp#"
     xml:base="https://cdm.ovh/edp"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:loca="https://cdm.ovh/rsm/localisation/loca#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:rlrs="https://cdm.ovh/rsm/linearReferencing/rlrs#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:topo="https://cdm.ovh/rsm/topology/topo#"
     xmlns:trfn="https://cdm.ovh/rsm/track/trfn#"
     xmlns:vann="https://vocab.org/vann/"
     xmlns:vann1="http://purl.org/vocab/vann/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://cdm.ovh/edp">
        <owl:imports rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/localisation/loca"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/topology/topo"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/track/trfn"/>
        <dc:creator>Airy Magnien</dc:creator>
        <dc:date>9 May 2026</dc:date>
        <dc:description>Eulynx Dataprep, adapted to Semantic RSM</dc:description>
        <dc:title>Eulynx Dataprep 1.2</dc:title>
        <dcterms:license>EUPL 1.2</dcterms:license>
        <rdfs:comment>Possibly with some further changes, e.g. using QUDT.</rdfs:comment>
        <rdfs:comment>UML/XMI→OWL transformation (lossy; no provenance).</rdfs:comment>
    </owl:Ontology>
    



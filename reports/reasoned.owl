        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#appliesToLevelCrossingSystem_BarrierMechanism"/>

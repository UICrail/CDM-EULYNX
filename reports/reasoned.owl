    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#DepartureTrack -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/ETCS#DepartureTrack">

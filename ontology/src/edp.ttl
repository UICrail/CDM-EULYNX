<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSectionConfiguration> a owl:Class ;
    rdfs:label "TdsSectionConfiguration" ;
    rdfs:comment """A set of properties that applies to a TDS section.
The class <a href="$element://{7B328390-6A51-4bc6-A2A2-1B6DAAB21DA4}"><font color="#0000ff"><u>insulated rail joint</u></font></a> informs which rail is cut for insulation.""",
        """isOverridable
True when the associated section is configured to allow override.
The override procedure allows the signaller to open a signal that is closed because the TDS section reports (presumably false) occupied.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#appliesToTdsSection> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSection> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAssetConfiguration> .


        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficSign"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingSpeedProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment"/>
        <rdfs:comment>A system that detects the absence of obstacles in the level crossing danger area.
The installation- and setup manuals can be attached or referred from this class.
An acceptance certificate is implied in the supplier information (OEM product name which is part of the supplier configuration property).
de-DE: Gefahrraumfreimeldeanlage
en-GB: crossing clear function</rdfs:comment>
        <rdfs:label>LevelCrossingClearanceDetectionSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingConfiguration -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingConfiguration">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAssetConfiguration"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#appliesToLevelCrossingSystem_LevelCrossingConfiguration"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSystem"/>

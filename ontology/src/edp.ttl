        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#toBaliseGroup> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsBaliseGroup> ],
        [ a owl:Restriction ;

            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Common#areaType> ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Common#assetName> ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Common#areaName> ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Common#assetType> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Designation> .


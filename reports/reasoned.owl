    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#Detonator_EAID_EB3494A6_19C4_477d_85EE_06E6A114EA1C -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#Detonator_EAID_EB3494A6_19C4_477d_85EE_06E6A114EA1C">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsSpotDevice"/>
        <rdfs:comment>A detonator creates an explosion to warn the driver about imminent danger ahead.</rdfs:comment>
        <rdfs:comment>type
Can inform about 
&lt;ul&gt;
	&lt;li&gt;on or off the rail.&lt;/li&gt;
	&lt;li&gt;trailable.&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>Detonator</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#LimitedCurrentArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#LimitedCurrentArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#maxTractionCurrent"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>LimitedCurrentArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NTC -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NTC">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#nid_ntc_NTC"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#SpeedCheckingSystemProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#SpeedProperties"/>
        <rdfs:label>NTC</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NoEddyCurrentBrakeArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NoEddyCurrentBrakeArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#isOfProhibitionType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>NoEddyCurrentBrakeArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NoRegenerativeBrakeArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NoRegenerativeBrakeArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea"/>
        <rdfs:label>NoRegenerativeBrakeArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NonStoppingArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NonStoppingArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#description_NonStoppingArea"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>NonStoppingArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#SpeedCheckingSystemProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#SpeedCheckingSystemProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#hasSpeedProperties"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#SpeedProperties"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#SpeedProperties"/>
        <rdfs:comment>For speed checking configurations with a speed checking section (also known as Overspeed sensor, OSS)</rdfs:comment>
        <rdfs:label>SpeedCheckingSystemProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#SpeedProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#SpeedProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#hasDesignSpeed"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Properties of a speed checking system are design speed and, optionally, train category.
The results from the design process are stored for validation purposes.</rdfs:comment>
        <rdfs:label>SpeedProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TiltingArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TiltingArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpArea"/>
        <rdfs:label>TiltingArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDataTransmissionSystemProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDeviceProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsProtectionDistance"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsRelation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrainSelectionProperties"/>
        <rdfs:comment>Area equipped with a Train Protection (TP) System.
If different directional TP systems are used in an area (border area), directional area locations must be created.</rdfs:comment>
        <rdfs:label>TpArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpMarker -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpMarker">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#ChangeMarker"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#hasChangeCondition"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#Condition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A mark from where Train Protection applies a (different) restriction. 
Use the inherited Description to annotate the ATP area demarcation (entry or exit point).</rdfs:comment>
        <rdfs:label>TpMarker</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpTransitionMarker -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpTransitionMarker">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpMarker"/>
        <rdfs:comment>A spot on the track where a train enters the control area of a another TP system.</rdfs:comment>
        <rdfs:label>TpTransitionMarker</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDataTransmissionSystem -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDataTransmissionSystem">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#VirtualTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#hasPropertySet_TpsDataTransmissionSystem"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDataTransmissionSystemProperties"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>System for transmitting train protection data. Also known as &lt;i&gt;Information Point.&lt;/i&gt;</rdfs:comment>
        <rdfs:label>TpsDataTransmissionSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDataTransmissionSystemProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDataTransmissionSystemProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDeviceProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsProtectionDistance"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsRelation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrainSelectionProperties"/>
        <rdfs:comment>isSwitchable
Indicates whether the system is switchable, e.g. a transparent balise group. Note: this information should concur with the  &quot;track asset is controlled by&quot; and the  &quot;balise is switchable&quot; attributes.</rdfs:comment>
        <rdfs:label>TpsDataTransmissionSystemProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDevice -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDevice">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:label>TpsDevice</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDeviceProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDeviceProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#appliesToTpsDevice_TpsDeviceProperties"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDevice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsProtectionDistance"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsRelation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrainSelectionProperties"/>
        <rdfs:label>TpsDeviceProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsLinearDevice -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsLinearDevice">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDevice"/>
        <rdfs:label>TpsLinearDevice</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsProtectionDistance -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsProtectionDistance">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#appliesToSignal_TpsProtectionDistance"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#value_TpsProtectionDistance"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsRelation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrainSelectionProperties"/>
        <rdfs:comment>The distance to a protected location that the TPS needs to halt a train.</rdfs:comment>
        <rdfs:label>TpsProtectionDistance</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsRelation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsRelation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrainSelectionProperties"/>
        <rdfs:comment>Informs at what distance the TP device or system is placed on approach to the signal. 
The signal could be a speed restriction board (NR approach).</rdfs:comment>
        <rdfs:label>TpsRelation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsSpotDevice -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsSpotDevice">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDevice"/>
        <rdfs:label>TpsSpotDevice</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrackConditionArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#isLocatedAt_TrackConditionArea"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrainSelectionProperties"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#BigMetalMassArea"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#LimitedCurrentArea"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NoEddyCurrentBrakeArea"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NoRegenerativeBrakeArea"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#NonStoppingArea"/>
        </owl:disjointUnionOf>
        <rdfs:comment>An area where a particular track condition applies.</rdfs:comment>
        <rdfs:label>TrackConditionArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrainSelectionProperties -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TrainSelectionProperties">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#appliesToTpsDevice_TrainSelectionProperties"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsDevice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#selectionDescription"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>TP devices can be train-selective. The TPS transmits information to the train such that only  &quot;suitable&quot; trains are allowed through.</rdfs:comment>
        <rdfs:label>TrainSelectionProperties</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#LockingDevice -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#LockingDevice">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#isHousedIn_LockingDevice"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A device, usually a track-side instrument, for locking and/or releasing pieces of infrastructure.</rdfs:comment>
        <rdfs:label>LockingDevice</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#LockoutArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#LockoutArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningArea"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningComponent"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningSystem"/>
        <rdfs:comment>Area under temporary possession, typically for maintenance activities.</rdfs:comment>
        <rdfs:label>LockoutArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#LockoutDevice -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#LockoutDevice">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#LockingDevice"/>
        <rdfs:comment>Device that allows line-side workers to lock out part of the network, thus claiming protection from trains.</rdfs:comment>
        <rdfs:label>LockoutDevice</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#PermanentWarningSystem -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#PermanentWarningSystem">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningSystem"/>
        <rdfs:comment>The warning system is permanently active; staff does not need to activate it.
The warning is triggered by an approaching train.</rdfs:comment>
        <rdfs:label>PermanentWarningSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#SwitchedWarningSystem -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#SwitchedWarningSystem">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningSystem"/>
        <rdfs:comment>The warning system can be switched on when staff is working track side.
The system is triggered by an approaching train.</rdfs:comment>
        <rdfs:label>SwitchedWarningSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningArea -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningArea">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningComponent"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningSystem"/>
        <rdfs:comment>The area fitted with a warning system that alerts line-side staff about impending danger.
The area can have a designation, name and other configuration items.</rdfs:comment>
        <rdfs:label>WarningArea</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningComponent -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningComponent">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningSystem"/>
        <rdfs:comment>Audible and/or visual alarm device.</rdfs:comment>
        <rdfs:comment>isDoubleSided
Direction of the alarm.
&lt;ul&gt;
	&lt;li&gt;True: the alarm is omnidirectional.&lt;/li&gt;
	&lt;li&gt;False: the alarm is directed.&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>WarningComponent</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningSystem -->


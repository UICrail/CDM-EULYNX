<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#InfrastructuralPlatformEdge> a owl:Class ;
    rdfs:label "InfrastructuralPlatformEdge" ;
    rdfs:comment "All of the platform edge adjacent to a track. Includes ramps, stairs, fenced off or restricted areas where trains don't normally stop." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#OperationalPlatformEdge> a owl:Class ;
    rdfs:label "OperationalPlatformEdge" ;
    rdfs:comment """Where passenger can access trains.
The definition is national. It depends on signal sighting, length of train, position of doors, height of steps, presence of barriers or signs.
It is possible to define an edge <i>per direction</i>, which can be relevant to coupling, splitting or turn-operations (NR and ProRail).""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformEdge> .


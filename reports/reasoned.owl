        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Common#type_TrafficFlow"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Defines fields for traffic flow modelling.</rdfs:comment>
        <rdfs:label>TrafficFlow</rdfs:label>
    </owl:Class>
    



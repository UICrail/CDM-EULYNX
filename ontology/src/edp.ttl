<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponentConfiguration> a owl:Class ;
    rdfs:label "MovableComponentConfiguration" ;
    rdfs:comment """A set of properties that applies to a movable component.
The number of point machines, as intended by EULYNX specification Eu.P.4957, is the sum of the number of point drives and external detectors.""",
        """numberOfExternalDetectors
The number of external blade position detectors.
This excludes detectors inside the drive mechanism. Not informed when attribute hasExternalDetectors is false.""",
        """numberOfPointDrives
The number of drives, that both drive and detect this movable component.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#appliesToMovableComponent> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponent> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAssetConfiguration> .


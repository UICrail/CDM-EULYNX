    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#RestrictedArea> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#VehicleStop> a owl:Class ;
    rdfs:label "VehicleStop" ;
    rdfs:comment "Installation for physically stopping trains. The track may continue beyond the device." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#PhysicalTrackAsset> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcConnector> a owl:Class ;
    rdfs:label "TcConnector" ;
    rdfs:subClassOf [ a owl:Restriction ;

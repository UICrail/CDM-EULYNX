<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#ActiveAspect> a owl:Class ;
    rdfs:label "ActiveAspect" ;
    rdfs:comment "Atomic dynamic information displayed by the signal." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#Aspect> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalAspectDegradation> a owl:Class ;
    rdfs:label "SignalAspectDegradation" ;
    rdfs:comment "Provides signal aspect degradation information that is associated with a given light signal.",
        """isMostRestrictive
True: the active aspect set is the most restrictive that the signal shows:
<ul>
	<li>when not controlled by the interlocking, e.g. in case of failed communication between interlocking and signal controller.</li>
	<li>during system start.</li>
</ul>
False: degrade to the given set of active aspects.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#isMostRestrictive> ;
            owl:someValuesFrom xsd:boolean ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#appliesToActiveAspectSet> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#ActiveAspectSet> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#Aspect>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessage>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalMessageRelation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Aspects_messages#SignalVector> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroupAssociation> a owl:Class ;
    rdfs:label "PopGroupAssociation" ;
    rdfs:comment """Class that allocates a signal to a POP group. Membership can be conditional.

The sensor that detects an overrun is given by rule; typically the first TDS section beyond the signal.""",
        """condition
Optional note describing a condition.
Could state that overrun of the signal doesn't replace other signals in the group.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#appliesToPopGroup> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#PopGroup> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#appliesToSignal_PopGroupAssociation> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal#Signal> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#AspectProving>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#BackToBackLocking>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#LensDiffuser>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#ManualOverlapRelease>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#NonStopMovement>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#OppositeTrackSignal>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Signal/Functional_model#SignalProperty> .


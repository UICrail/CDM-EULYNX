            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#appliesValence_DoubleLogicalOutputChannel"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#hasValidationChannel_DoubleLogicalOutputChannel"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#PhysicalOutputChannel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A logical boolean output communication channel. The value of the physical reference and validation outputs dictate the value of the logical input.</rdfs:comment>
        <rdfs:label>DoubleLogicalOutputChannel</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#LogicalChannel -->


    rdfs:label "LevelCrossingActivationTypes" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#scheme_Quadrants_EAID_4124D9EB_0C1E_4b58_8A6C_77C4D79AE4EA> a skos:ConceptScheme ;

    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#KvbInformationField -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#KvbInformationField">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#normalDirection"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#remarks_KvbInformationField"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#KvbSpeedDesignProperties"/>
        <rdfs:comment>normalDirection
true: information works in the normal direction.
false: works in reverse direction.

Normal/reverse refers to the orientation of the balise group.</rdfs:comment>
        <rdfs:label>KvbInformationField</rdfs:label>
    </owl:Class>
    



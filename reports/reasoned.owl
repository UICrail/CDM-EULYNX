        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#appliesToLevelCrossingActivation_LevelCrossingRouteRelation"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSignalRelation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingTimerSet"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RadarReflector"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#RoadTrafficSign"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossingSpeedProperties"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrafficMoment"/>
        <rdfs:comment>Activation can depend on the route or route body. This allows delaying level crossing closure depending on the route/route body, or preventing the level crossing from closing if the route leads the train away from it.</rdfs:comment>
        <rdfs:label>LevelCrossingRouteRelation</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSignalRelation -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSignalRelation">

        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#StandstillDetectionForShunting"/>
        <rdfs:comment>Defines the conditions for ending the display of a text message. The conditions are 
&lt;ul&gt;
	&lt;li&gt;length or duration, as described in the subset&lt;/li&gt;
	&lt;li&gt;ERTMS level&lt;/li&gt;
	&lt;li&gt;mode&lt;/li&gt;
&lt;/ul&gt;</rdfs:comment>
        <rdfs:label>EtcsTextDisplayEndCondition</rdfs:label>
    </owl:Class>
    



        <skos:inScheme rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Assets/Train_detection#scheme_RouteReleaseTypes_EAID_403B2B8A_44E2_4a74_91E1_99FF3B4C9AFE"/>

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#KvbInformationField> a owl:Class ;
    rdfs:label "KvbInformationField" ;
    rdfs:comment """normalDirection
true: information works in the normal direction.
false: works in reverse direction.

Normal/reverse refers to the orientation of the balise group.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#normalDirection> ;
            owl:someValuesFrom xsd:boolean ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#remarks_KvbInformationField> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#KvbSpeedDesignProperties> .


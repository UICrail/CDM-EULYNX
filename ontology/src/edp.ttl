<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#SelfSupervisedLevelCrossing> a owl:Class ;
    rdfs:label "SelfSupervisedLevelCrossing" ;
    rdfs:comment "A <b>LX</b> system that has the logic to autonomously process triggers from route setting and/or train approach. The LX warns and/or closes the barriers when activated. The LX reports failures to the interlocking.",
        "The difference is that the interlocking logic uses I/O from the self-supervised level crossing, but does not use I/O from the locally-monitored level crossing." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#IntegratedLevelCrossing> .


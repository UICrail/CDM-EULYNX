    rdfs:label "TcBondTypes" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteJunctionNode> a owl:Class ;
    rdfs:label "CableRouteJunctionNode" ;
    rdfs:comment """A physical node in the cable route network where cables can enter/exit a cable route. From this hub the cable route goes to controller, controlled track asset, cable distributor or housing.
This class can be instantiated if no appropriate specialised class is available, for instance at an early planning stage.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteNode> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteNode> a owl:Class ;
    rdfs:label "CableRouteNode" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointUnionOf ( <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteTerminationNode> <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRouteJunctionNode> ) ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#Cable>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJointInstallation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#EtcsBalise> a owl:Class ;
    rdfs:label "EtcsBalise" ;
    rdfs:comment """Eurobalise in an ETCS system.
The model type as defined by the manufacturer can be described in the <a href="$feature://{3D2A1B2D-BBA0-4bce-8064-8F86DBA8783F}"><font color="#0000ff"><u>Supplier Information class.</u></font></a>
Variable N_PIG is inherited from attribute "positionInSystem".""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#Balise> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#LeuSystem> a owl:Class ;
    rdfs:label "LeuSystem" ;
    rdfs:comment "A Lineside Electronic Unit (LEU) system controls zero or more ETCS balises." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#hasLeuPort_LeuSystem> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/ETCS#LeuPort> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#FieldObjectController> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Local_operating_area#LozLcDangerAreaTrackRelation> a owl:Class ;
    rdfs:label "LozLcDangerAreaTrackRelation" ;
    rdfs:comment """The level crossing's track-related danger area is conditional to the LOZ activation. 
This allows the scenario where a level crossing across more than one track is partly under local control (in a LOZ), partly under control of the interlocking.
If the level crossing system as a whole is part of a LOZ, then use the LozLevelCrossingRelation.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Local_operating_area#appliesToDangerAreaTrack_LozLcDangerAreaTrackRelation> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#DangerAreaTrack> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Local_operating_area#LozAssetRelation> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#CompositeRoute> a owl:Class ;
    rdfs:label "CompositeRoute" ;
    rdfs:comment "A route that is composed of two or more elementary routes. The elementary routes are commonly referred to as atomic routes or subroutes." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#ConflictingRoute>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#RouteApproachLocking>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#RouteBody>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#RouteCondition> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#NonReplacement> a owl:Class ;
    rdfs:label "NonReplacement" ;
    rdfs:comment "To prevent a signal from closing too early. The signal is replaced only after \"<i>condition section occupied\" </i>and \"<i>last wheel\" </i>apply.",
        """lastWheel
False (default): the entry signal is replaced when the first wheel enters the next section. 

True: the entry signal is replaced only when the last wheel of the train has cleared the non-replacement section.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#lastWheel> ;
            owl:someValuesFrom xsd:boolean ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#appliesToRoute_NonReplacement> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#Route> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#CompositeRoute>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#ConflictingRoute>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#Route>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#RouteApproachLocking>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#RouteBody>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#RouteCondition> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RouteAvailableInARS> a owl:Class ;
    rdfs:label "RouteAvailableInARS" ;
    rdfs:comment "This route is available in an Automatic Route Setting (ARS) system." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RouteProperty> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#AutoRoute> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RoutePriority> a owl:Class ;
    rdfs:label "RoutePriority" ;
    rdfs:comment """Indicates the priority of the route 
<ul>
	<li>when there is only one route from entry to exit, priority=0</li>
	<li>when there are multiple routes from entry to exit, the lowest number has highest priority. Alternative routes are numbered 1..n</li>
</ul>
This allows a control system to attribute priorities to route setting. Whether or not the control system auto-selects lower priority routes when no higher priority route is available, depends on national rules and regulations.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#value_RoutePriority> ;
            owl:someValuesFrom xsd:integer ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RouteProperty> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#AutoRoute>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Route_properties#RouteAvailableInARS> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_describer#scheme_DisplayFieldFunctionTypes_EAID_27B5D7FE_FB39_4871_A513_4F87473DD8D7> a skos:ConceptScheme ;
    rdfs:label "DisplayFieldFunctionTypes" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#SpeedCheckingSystemProperties> a owl:Class ;
    rdfs:label "SpeedCheckingSystemProperties" ;
    rdfs:comment "For speed checking configurations with a speed checking section (also known as Overspeed sensor, OSS)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#hasSpeedProperties> ;

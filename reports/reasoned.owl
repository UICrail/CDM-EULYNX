    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#BarrierBoom -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#BarrierBoom">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>

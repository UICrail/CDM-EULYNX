        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:inScheme rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#scheme_OverlapReleaseConditionTypes_EAID_69ACD5BF_946E_43e2_B85E_CBA4580E50F7"/>

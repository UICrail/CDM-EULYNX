        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#WarningSystem> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#scheme_AlarmTypes_EAID_B1CC6284_AC89_480b_8F46_8BC018606693> a skos:ConceptScheme ;
    rdfs:label "AlarmTypes" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationOfInterest> a owl:Class ;
    rdfs:label "LocationOfInterest" ;
    rdfs:comment """Point of interest to the signalling system.
Often a location that is well-identifiable, e.g. as to attract attention to a dangerpoint, e.g. to the tip of a point or gauge conflict or end of platform. 
Can be used for specifying dangerpoints, end of overlap or ATP protected location, a location where speed changes.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#isLocatedAt_LocationOfInterest> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationProxy> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#MappingView> a owl:Class ;
    rdfs:label "MappingView" ;
    rdfs:comment "The cut-out of a map that is overlaid on the drawing of the track. The area location is defined by means of corner coordinates in both geographical and paper coordinates such that the overlay fits. This creates a view of rail and civil utility layers needed to design level crossings." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#refersToAttachedMap> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Attachment> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#AssetUser>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Edge>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideInstallation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationProxy>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Node>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OperationalLocality>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawing>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Segment>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#View> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#AnchorPoint> a owl:Class ;
    rdfs:label "AnchorPoint" ;
    rdfs:comment """Class for enriching the RSM anchor point with configuration properties such as designation and applicable rule set. 
Can be used to represent kilometre-posts and chainage breaks.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#refersToRegisteredIntrinsicCoord> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#RegisteredIntrinsicCoordinate> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#appliesToLine> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#Line> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject>,
        rlrs:AnchorPoint ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#Line>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Geo_information#LinearElement>,

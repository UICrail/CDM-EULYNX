<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#AxleCountingSection> a owl:Class ;
    rdfs:label "AxleCountingSection" ;
    rdfs:comment "An Axle counting system detects rolling stock in a logical section by counting incoming and outgoing wheels." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#isOfResetStrategyType> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TdsSection> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#EMSensor> a owl:Class ;
    rdfs:label "EMSensor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#numberOfHeads> ;
            owl:someValuesFrom xsd:integer ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#VehicleSensor> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#HviTrackCircuit> a owl:Class ;

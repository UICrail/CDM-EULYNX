            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>AutomaticRouteSettingSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Automatic_route_setting#SequenceMonitor -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Automatic_route_setting#SequenceMonitor">

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Local_operating_area#LozAssetRelation> a owl:Class ;
    rdfs:label "LozAssetRelation" ;
    rdfs:comment """Assigns an asset to a local operating zone.
Optionally defines the condition for taking or returning the zone from/to the signaller.""",
        """controllable
Indicates whether the local operator has full control (true, default) or not (false) over the asset when the local operating zone is active. Applies only to signal, point and derailer.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Local_operating_area#controllable_LozAssetRelation> ;
            owl:someValuesFrom xsd:boolean ],

    rdfs:range <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#TrackCrossing> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#comment> a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:domain <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Annotation> ;
    rdfs:range xsd:string .


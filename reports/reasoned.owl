    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideSpotSystem -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideSpotSystem">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideInstallation"/>
        <rdfs:comment>Facade for spot-located devices such as hot axle box detector, telecom antenna, catenary post, track lubricator.</rdfs:comment>
        <rdfs:label>LineSideSpotSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LinkedAttachment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LinkedAttachment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Attachment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#link"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>LinkedAttachment</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationDescription -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationDescription">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationProxy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#referencePoint"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Describes a location by an asset that is not part of the data set but referenced within an other data set (outside the current EULYNX XML).</rdfs:comment>
        <rdfs:label>LocationDescription</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationOfInterest -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationOfInterest">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationProxy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#isLocatedAt_LocationOfInterest"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Point of interest to the signalling system.
Often a location that is well-identifiable, e.g. as to attract attention to a dangerpoint, e.g. to the tip of a point or gauge conflict or end of platform. 
Can be used for specifying dangerpoints, end of overlap or ATP protected location, a location where speed changes.</rdfs:comment>
        <rdfs:label>LocationOfInterest</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationProxy -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationProxy">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#MappingView"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Node"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OperationalLocality"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawing"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Segment"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#View"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationDescription"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationOfInterest"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationReference"/>
        </owl:disjointUnionOf>
        <rdfs:comment>Facade for a location that may, or not, be associated with an asset.</rdfs:comment>
        <rdfs:label>LocationProxy</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationReference -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationReference">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LocationProxy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#refersToTrackAsset_LocationReference"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets#TrackAsset"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Reference to the protected infrastructure object &lt;i&gt;e.g. a signal or fouling point.&lt;/i&gt;</rdfs:comment>
        <rdfs:label>LocationReference</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#MappingView -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#MappingView">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#refersToAttachedMap"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Attachment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Node"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OperationalLocality"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawing"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Segment"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#View"/>
        <rdfs:comment>The cut-out of a map that is overlaid on the drawing of the track. The area location is defined by means of corner coordinates in both geographical and paper coordinates such that the overlay fits. This creates a view of rail and civil utility layers needed to design level crossings.</rdfs:comment>
        <rdfs:label>MappingView</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Node -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Node">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OperationalLocality"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawing"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Segment"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#View"/>
        <rdfs:label>Node</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Note -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Note">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#AdditionalInformation"/>
        <rdfs:label>Note</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ObjectInView -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ObjectInView">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#refersToObject_ObjectInView"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawingParameter"/>
        <rdfs:comment>The position of an object in a specific view.</rdfs:comment>
        <rdfs:label>ObjectInView</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ObjectStatus -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ObjectStatus">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfigurationProperty"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#isControlled"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#isInFunctionalPosition"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SourceInformation"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#SupplierInformation"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#CoveredObject"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#DummyMode"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OtherObjectStatus"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OutOfService"/>
        </owl:disjointUnionOf>
        <rdfs:comment>An object-configuration can reflect a particular status, typically in construction phases.
For instance, a signal can be disconnected so drivers disregard the signal. The signal would then own a configuration associated with an out-of-service status.
This abstract class reflects an object status and the IM can specialise the object status that describes national needs.</rdfs:comment>
        <rdfs:label>ObjectStatus</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OperationalLocality -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OperationalLocality">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#abbreviation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#longName_OperationalLocality"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#shortName_OperationalLocality"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#type_OperationalLocality"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawing"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Segment"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#View"/>
        <rdfs:comment>Yard, region or zone for administrative purposes, without further technical definitions.
NR: used for rail nodes. Assets are not linked to an operational locality but rather to the signal box, which maps to a control area.</rdfs:comment>
        <rdfs:label>OperationalLocality</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OtherObjectStatus -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OtherObjectStatus">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ObjectStatus"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#description_OtherObjectStatus"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>OtherObjectStatus</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OutOfService -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OutOfService">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ObjectStatus"/>
        <rdfs:label>OutOfService</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OutOfServicebyInstructionOnly -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OutOfServicebyInstructionOnly">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#OutOfService"/>
        <rdfs:label>OutOfServicebyInstructionOnly</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#PullWire -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#PullWire">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#LineSideDetector"/>
        <rdfs:label>PullWire</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawing -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#parameterizedBy"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawingParameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#name_ReferenceDrawing"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#subtitle"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#title"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#variant"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Segment"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#View"/>
        <rdfs:comment>Pointer to (a set of) reference drawings (aka control drawings) for civil and mechanical engineering purposes. May range from a reference to paper documents to 3D CAD-files.
National end-users can tailor this class to their needs.
Not to be used for drawings of &lt;i&gt;specific &lt;/i&gt;objects: instantiate an Attachment class instead.</rdfs:comment>
        <rdfs:comment>other
In case &apos;other&apos; is chosen, a reference drawing must be referred to.
de-DE: sonstige; bei Auswahl des Werts &apos;sonstige&apos; ist eine Profilzeichnung als Reference Drawing beizulegen.</rdfs:comment>
        <rdfs:label>ReferenceDrawing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawingParameter -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ReferenceDrawingParameter">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#name_ReferenceDrawingParameter"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#value_ReferenceDrawingParameter"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Some reference drawings contain parameterised sketches that need a specific value in a concrete engineering planning. This concrete value is stored as a key-value pair where the key is the name of the parameter in the drawing and the value is the applicable value.</rdfs:comment>
        <rdfs:label>ReferenceDrawingParameter</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Segment -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#Segment">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#View"/>
        <rdfs:label>Segment</rdfs:label>
    </owl:Class>
    



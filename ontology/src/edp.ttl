            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#maxPowerConsumption> ;
            owl:someValuesFrom xsd:integer ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Track#SpecialGauge> a owl:Class ;

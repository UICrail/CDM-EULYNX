        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#code_Key"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#Lock"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#LockCombination"/>
        <rdfs:comment>A (physical) key to unlock a device.</rdfs:comment>
        <rdfs:label>Key</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#KeyReleaseInstrument -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#KeyReleaseInstrument">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#ReleaseInstrument"/>
        <rdfs:comment>A device that releases control over an asset by releasing a key.
When the key is released, the interlocking gets no status information about the track asset, and the staff can use the key to mechanically unlock and work the asset locally.
The instrument &quot;hides&quot; the locked element from the interlocking.</rdfs:comment>
        <rdfs:label>KeyReleaseInstrument</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#Lock -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#Lock">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#acceptsKey"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#Key"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#captiveKey"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#LockCombination"/>
        <rdfs:comment>The lock accepts a key and locks out one or more track assets from interlocking control.</rdfs:comment>
        <rdfs:comment>captiveKey
True: the key is normally in.
False: the key is normally out.</rdfs:comment>
        <rdfs:label>Lock</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#LockCombination -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#LockCombination">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#isHousedIn_LockCombination"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Housing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A combination of one master lock and a set of dependent locks.
Either the master lock or all dependent locks are unlocked.</rdfs:comment>
        <rdfs:label>LockCombination</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#PointLock -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#PointLock">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#Lock"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#isMountedOnSide_PointLock"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Lock attached to a clamp that prevents point blades from moving. The movable element is found through the asset-in-state relation.
Not to be confused with the &lt;a href=&quot;$element://{5843BDE9-40E5-45da-9B71-D296F1DD076B}&quot;&gt;&lt;font color=&quot;#0000ff&quot;&gt;&lt;u&gt;facing point lock&lt;/u&gt;&lt;/font&gt;&lt;/a&gt; which is  a (remotely operated) movable component.</rdfs:comment>
        <rdfs:label>PointLock</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#ReleaseInstrument -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#ReleaseInstrument">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Working_safety#LockingDevice"/>
        <rdfs:comment>A device that releases control of an asset.</rdfs:comment>
        <rdfs:label>ReleaseInstrument</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#ShutInSidingKeyReleaseInstrument -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#ShutInSidingKeyReleaseInstrument">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Key_locks#KeyReleaseInstrument"/>
        <rdfs:comment>Key release instrument specific to shunting sidings on open line.
It isolates (en-UK: &lt;i&gt;shuts in&lt;/i&gt;) the shunting yard from the main running line.</rdfs:comment>
        <rdfs:label>ShutInSidingKeyReleaseInstrument</rdfs:label>
    </owl:Class>
    



        <rdfs:label>TunnelTube</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#View -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#View">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject"/>

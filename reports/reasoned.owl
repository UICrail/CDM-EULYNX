                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>trailable
fr-FR: Crocodile talonnable, equip&amp;#233; d&apos;une p&amp;#233;dale pour annuler le crocodile lorsqu&apos;il est franchi en sens inverse.</rdfs:comment>
        <rdfs:label>CrocodileSystemProperties</rdfs:label>
    </owl:Class>
    



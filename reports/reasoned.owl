            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbNgLoop"/>
            <rdf:Description rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbVvLoop"/>
        </owl:disjointUnionOf>
        <rdfs:label>AtbLoop</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbNgBeacon -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbNgBeacon">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Train_protection#TpsSpotDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#isPsrBeacon"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>AtbNgBeacon</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbNgLoop -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbNgLoop">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbLoop"/>
        <rdfs:label>AtbNgLoop</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbVvBeacon -->


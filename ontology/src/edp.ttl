        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#DispatchPosition>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Platform#PlatformAccess> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Diamond> a owl:Class ;
    rdfs:label "Diamond" ;
    rdfs:comment "The lozenge shape where the rails intersect in a crossing." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#isLocatedAt_Diamond> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#PointHeating> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#LocatedMovableComponent> a owl:Class ;
    rdfs:label "LocatedMovableComponent" ;
    rdfs:comment """A movable component that is spot-located but not specified in the signalling domain, e.g. movable bridges, water barriers. 
The subtypes of this class represent movable components that are specified in the signalling domain.""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableComponent> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#Normalisation> a owl:Class ;
    rdfs:label "Normalisation" ;
    rdfs:comment "The movable element returns to the preferred position when it is no longer claimed by a route, typically because the passing train has cleared the movable element." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#appliesToMovableElement_Normalisation> ;

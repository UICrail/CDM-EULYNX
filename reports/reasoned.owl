            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/NR/Train_protection#appliesToNeutralSection"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Power_supply_traction#ElectrificationGap"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Automatic Power Control Magnet.
Strictly speaking, this is not a train protection device but it uses the same technology to transmit information about the neutral section.</rdfs:comment>
        <rdfs:label>ApcMagnet</rdfs:label>
    </owl:Class>
    



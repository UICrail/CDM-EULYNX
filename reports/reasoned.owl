                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>See SNCF document DES258/IG33258 for details about the properties in this class.</rdfs:comment>

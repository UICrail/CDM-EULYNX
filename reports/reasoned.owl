        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#Cabinet"/>
        <rdfs:comment>Small line-side cabinet for housing the ATB VV controller. It is spot located.
nl-NL: Aansluitkast (ASK)</rdfs:comment>
        <rdfs:label>AtbVvConnectionCabinet</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbVvController -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/ProRail/Train_protection#AtbVvController">

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#BidirectionalRouteLocking> a owl:Class ;
    rdfs:label "BidirectionalRouteLocking" ;
    rdfs:comment """Opposing route locking for routes in areas with points.
fr-FR: Enclenchement de parcours banalis&#233; (dans les zones &#233;quip&#233;es d'appareils de voie).
Les conditions d'&#233;tablissement de l'itin&#233;raire ne requi&#232;rent que la v&#233;rification du transit de sens contraire en aval du signal origine de l'itin&#233;raire (e.g. pour v&#233;rifier qu'aucun intin&#233;raire de sens contraire form&#233; a pour destination un signal en amont du signal origine).""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#checksTransit_BidirectionalRouteLocking> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Transit_EAID_ACED038E_2CE8_4f0d_BB9E_FD9C5E14F957> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#OpposingRouteLocking> .

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#DirectionLocking> a owl:Class ;
    rdfs:label "DirectionLocking" ;
    rdfs:comment """fr-FR: Enclenchement de sens entre postes.
Checks to prevent simultaneous opening of opposing signals that are controlled by different interlocking systems.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#hasInterval_DirectionLocking> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Interval_EAID_FE95BDFD_02BE_415c_A7AE_A02DD147121E> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking> .

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#SingleTrackLocking> a owl:Class ;
    rdfs:label "SingleTrackLocking" ;
    rdfs:comment """Used case of single track, i.e. the opposing routes are part of one yard controlled by a single interlocking.

fr-FR: Voie Unique (VU)
Une voie unique dans le poste est une portion de voie d&#233;limit&#233;e par deux signaux de sens contraire dos &#224; dos. Est v&#233;rifi&#233; que le transit de sens contraire de la zone de la VU est lib&#233;r&#233;. Si c'est le cas, le sens de la VU est pris et l'itin&#233;raire s'&#233;tablit.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#hasInterval_SingleTrackLocking> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Interval_EAID_FE95BDFD_02BE_415c_A7AE_A02DD147121E> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking> .

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#StandoffLocking> a owl:Class ;
    rdfs:label "StandoffLocking" ;
    rdfs:comment "fr-FR: Enclenchement d'affrontement." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#manualReleasePossible> ;
            owl:someValuesFrom xsd:boolean ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking> .

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#StationTrackLocking> a owl:Class ;
    rdfs:label "StationTrackLocking" ;
    rdfs:comment """Allows shunting movement on track situated between the opposing signals.

fr-FR: enclenchement de voie de stationnement (St).
Typiquement utilis&#233; pour une voie &#224; quai. Le transit qui donne acc&#232;s &#224; la voie de stationnement en sens contraire est v&#233;rifi&#233;. Permet de manoeuvrer (e.g. pour coupler deux rames ou atteler une locomotive). 

Comme une VU, sauf que l'on peut y manoeuvrer (pour coupler deux rames ou pour atteler une locomotive). Au lieu de v&#233;rifier le transit de sens contraire de la VU, est v&#233;rifi&#233; le transit qui donne acc&#232;s &#224; la voie de stationnement en sens contraire.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#hasInterval_StationTrackLocking> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#Interval_EAID_FE95BDFD_02BE_415c_A7AE_A02DD147121E> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#TrackLocking> .

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Route#scheme_SncfDirectionTypes_EAID_05E2C72C_4616_4da0_966B_CFB456142690> a skos:ConceptScheme ;
    rdfs:label "SncfDirectionTypes" .

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#KvbCsspInformationField> a owl:Class ;
    rdfs:label "KvbCsspInformationField" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#hasKvbCsspInformationType> ;
            owl:someValuesFrom owl:Thing ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/SNCF/Train_protection#KvbInformationField> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#Interlocking> a owl:Class ;
    rdfs:label "Interlocking" ;
    rdfs:comment "An interlocking system that has a control relationship with track-assets and/or controllers in a yard." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#Controller> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#IoController> a owl:Class ;
    rdfs:label "IoController" ;
    rdfs:comment """Controller for receiving binary inputs and sending binary outputs to and fro field elements.
<ul>
	<li>Inputs, typically received from relay contacts, are packed into telegrams and sent to the interlocking.</li>
</ul>
<ul>
	<li>Telegrams received from the interlocking are converted to binary outputs.</li>
</ul>""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#FieldObjectController> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#IpAddress> a owl:Class ;
    rdfs:label "IpAddress" ;
    rdfs:comment "A single IP address." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#IpAddressBlock> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#TrafficControlSystem> a owl:Class ;
    rdfs:label "TrafficControlSystem" ;
    rdfs:comment """A Traffic Control System is located in a signal box.
The technology string can indicate for instance "Digital traffic control system".""" ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#Controller> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller#scheme_IPversions_EAID_015AC0FE_48B9_4c1e_BC9B_DA605CDBE902> a skos:ConceptScheme ;
    rdfs:label "IPversions" .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#DoubleLogicalOutputChannel> a owl:Class ;
    rdfs:label "DoubleLogicalOutputChannel" ;
    rdfs:comment "A logical boolean output communication channel. The value of the physical reference and validation outputs dictate the value of the logical input." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Controller/EULYNX_Generic_IO#appliesValence_DoubleLogicalOutputChannel> ;

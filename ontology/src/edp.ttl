<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#TcFeederReceiverElement> a owl:Class ;
    rdfs:label "TcFeederReceiverElement" ;
    rdfs:comment """Track side devices for feeding AC signals into and receiving the same from track circuits. 
A feeder and receiver can share a spot location.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Train_detection#isOfFeederReceiverType> ;

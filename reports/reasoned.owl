    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#FreeHangingCableRoute -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#FreeHangingCableRoute">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute"/>
        <rdfs:label>FreeHangingCableRoute</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#MouldedCableJoint -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#MouldedCableJoint">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableJoint"/>
        <rdfs:comment>A cable joint connect two cable ends. It is not housed but lies in the cable route. Typically used when one runs out of cable or to repair sectioned cable. It is often molded in a resin.</rdfs:comment>
        <rdfs:label>MouldedCableJoint</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#RaisedCableTrough -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#RaisedCableTrough">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute"/>
        <rdfs:label>RaisedCableTrough</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#TemporaryCableRoute -->

    <owl:Class rdf:about="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#TemporaryCableRoute">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Cabling#CableRoute"/>

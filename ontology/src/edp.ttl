<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/DB/Train_describer#TrainDescriberTelegram> a owl:Class ;
    rdfs:label "TrainDescriberTelegram" ;
    rdfs:comment """The telegrams of the given type shall be sent for every shunting/main route.
de-DE: F&#252;r alle Fahrstra&#223;en und diesen ZN soll das Telegramm 84/85 gesendet werden.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/DB/Train_describer#isGeneratedByTrDrSystem> ;

            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectStageMetaData> ],
        [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#correctionType> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Actor>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#Organisation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Project_management#ProjectMetaData>,

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#NotUpgradeableSpeedRestriction> a owl:Class ;
    rdfs:label "NotUpgradeableSpeedRestriction" ;
    rdfs:comment """An overlap can cause a speed restriction in the approach route. 
This class lists the overlaps for which the speed isn't upgraded when the exit signal opens.
For an overlap not in the list, the IL lifts the speed restriction when the exit signal opens.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#appliesToOverlap_NotUpgradeableSpeedRestriction> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#Overlap> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#BaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#OverlapRelease> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route/Safety_distance#scheme_OverlapReleaseConditionTypes_EAID_69ACD5BF_946E_43e2_B85E_CBA4580E50F7> a skos:ConceptScheme ;
    rdfs:label "OverlapReleaseConditionTypes" ;
    rdfs:comment """startTimerAfterVacating
Overlap release timer starts when train clears the TVP section. 
Typically used in reversing scenarios.""",
        """startTimerUponOccupation
Overlap release timer starts when train occupies the TVP section, normally the berthing track.""",
        """trainInitiatedTrigger
Trackside releases the overlap only after train is proven in standstill by ETCS system or by a manual command.""" .


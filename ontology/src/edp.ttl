<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Route#ShuntingRoute> a owl:Class ;
    rdfs:label "ShuntingRoute" ;
    rdfs:comment """A route for maneuvering on occupied track. TVP sections are not checked for vacancy before calling this type of route. 
If section proving is required, use the extension of this class defined in the related section proving diagram.""" ;

<https://cdm.ovh/edp/EULYNX_DataPrep/National_implementations/DB/ETCS#PredefinedEtcsTelegramSet> a owl:Class ;
    rdfs:label "PredefinedEtcsTelegramSet" ;
    rdfs:comment "A predefined set of ETCS telegrams that a balise group sends in a given context such as a signal aspect." ;

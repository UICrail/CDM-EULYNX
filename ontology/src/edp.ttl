<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivationDelaySet> a owl:Class ;
    rdfs:label "LevelCrossingActivationDelaySet" ;
    rdfs:comment "Allows storing a set of activation delays." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#hasCalculatedActivationDelay> ;
            owl:someValuesFrom xsd:string ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#DangerAreaTrack>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingClearanceDetectionSystem>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingControllerFailureReporting>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingTimerSet> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingRouteRelation> a owl:Class ;
    rdfs:label "LevelCrossingRouteRelation" ;
    rdfs:comment "Activation can depend on the route or route body. This allows delaying level crossing closure depending on the route/route body, or preventing the level crossing from closing if the route leads the train away from it." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#appliesToLevelCrossingActivation_LevelCrossingRouteRelation> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivation> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#DangerAreaTrack>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingActivationDelaySet>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingClearanceDetectionSystem>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingControllerFailureReporting>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingSignalRelation>,
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Level_crossing#LevelCrossingTimerSet> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#MovableElementAndPosition> a owl:Class ;
    rdfs:label "MovableElementAndPosition" ;
    rdfs:comment """normal
If normal=true: the given position is the <b>normal </b>position (the other position is the <b>reverse </b>position).
If this attribute isn't given, then neither normal nor reverse position is defined.""",
        """preferred
If preferred=true: the given position is the <b>preferred </b>position (the position to which the movable element returns when no longer claimed by a route).
If this attribute isn't given, then there is no preferred position.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#refersToMovableElement_MovableElementAndPosition> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Point_crossing_derailer#MovableElement> ],
        <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Statespace#AssetAndState> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#EquipmentSupport> a owl:Class ;
    rdfs:label "EquipmentSupport" ;
    rdfs:comment "Generalization of fixings and housings, defined as civil structures that can support (or house) signalling equipment." ;
    rdfs:subClassOf <https://cdm.ovh/edp/EULYNX_DataPrep/Generic/Common#ConfiguredBaseObject> ;
    owl:disjointWith <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Assets/Support_structures#CivilStructure> .

<https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsRoute> a owl:Class ;
    rdfs:label "ArsRoute" ;
    rdfs:comment "A route as known in the interlocking plus parameters used to configure the route request." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#evaluatesSectionGroup> ;
            owl:someValuesFrom <https://cdm.ovh/edp/EULYNX_DataPrep/Signalling/Automatic_route_setting#ArsDeadlockSectionGroup> ],
        [ a owl:Restriction ;
